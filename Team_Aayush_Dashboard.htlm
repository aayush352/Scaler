<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Team Aayush — Scaler Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Bricolage+Grotesque:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --ink: #0d0d12;
  --ink2: #1a1a24;
  --ink3: #252535;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #f0f0f8;
  --muted: #6b6b88;
  --muted2: #9898b8;
  --accent: #c8ff57;
  --accent-dim: rgba(200,255,87,0.12);
  --accent-dim2: rgba(200,255,87,0.06);
  --blue: #4a9eff;
  --blue-dim: rgba(74,158,255,0.12);
  --coral: #ff6b6b;
  --coral-dim: rgba(255,107,107,0.12);
  --purple: #a78bfa;
  --purple-dim: rgba(167,139,250,0.12);
  --amber: #fbbf24;
  --amber-dim: rgba(251,191,36,0.12);
  --teal: #34d399;
  --teal-dim: rgba(52,211,153,0.12);
  --r: 10px;
  --r-sm: 6px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'IBM Plex Mono', monospace; background: var(--ink); color: var(--text); min-height: 100vh; font-size: 13px; }

/* ── SECTION NAV (top-level: Marketing / CRM / Audit / Completion) ── */
.section-nav { background: #111118; border-bottom: 1px solid var(--border); padding: 0 28px; display: flex; align-items: center; gap: 0; height: 44px; position: sticky; top: 0; z-index: 60; }
.section-nav-brand { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 15px; color: var(--accent); letter-spacing: -0.5px; margin-right: 36px; white-space: nowrap; }
.section-nav-brand span { color: var(--muted2); font-weight: 400; }
.section-tab { padding: 0 20px; height: 100%; display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 500; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; white-space: nowrap; letter-spacing: 0.3px; position: relative; }
.section-tab:hover { color: var(--text); }
.section-tab.active { color: var(--text); border-bottom-color: var(--text); }
.section-tab.active.s-marketing { color: var(--accent); border-bottom-color: var(--accent); }
.section-tab.active.s-crm { color: var(--blue); border-bottom-color: var(--blue); }
.section-tab.active.s-audit { color: var(--amber); border-bottom-color: var(--amber); }
.section-tab.active.s-completion { color: var(--teal); border-bottom-color: var(--teal); }
.section-tab-icon { font-size: 13px; line-height: 1; }
.section-tab-soon { font-size: 8.5px; padding: 1px 5px; border-radius: 3px; background: var(--ink3); color: var(--muted); margin-left: 2px; }

/* ── TOP NAV (ARPU tabs — shown only under Marketing) ── */
.top-nav { background: var(--ink2); border-bottom: 1px solid var(--border); padding: 0 28px; display: flex; align-items: center; gap: 0; height: 48px; position: sticky; top: 44px; z-index: 50; }
.top-nav-brand { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 15px; color: var(--accent); letter-spacing: -0.5px; margin-right: 32px; white-space: nowrap; }
.top-nav-brand span { color: var(--muted2); font-weight: 400; }
.main-tab { padding: 0 18px; height: 100%; display: flex; align-items: center; font-size: 11.5px; font-weight: 500; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; white-space: nowrap; letter-spacing: 0.3px; }
.main-tab:hover { color: var(--text); }
.main-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.main-tab.disabled { opacity: 0.4; cursor: not-allowed; }

/* ── PLACEHOLDER SECTION PANELS ── */
.section-placeholder { padding: 60px 28px; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; }
.section-placeholder-icon { font-size: 48px; margin-bottom: 20px; opacity: 0.4; }
.section-placeholder-title { font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 8px; }
.section-placeholder-sub { font-size: 12px; color: var(--muted); max-width: 420px; line-height: 1.7; }
.section-placeholder-badge { display: inline-flex; align-items: center; gap: 6px; margin-top: 20px; padding: 7px 16px; border-radius: 20px; font-size: 11px; font-weight: 500; border: 1px solid; }

/* ── CRM MODULE STYLES ── */
.crm-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 20px; }
.crm-card { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); padding: 18px 20px; position: relative; overflow: hidden; }
.crm-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; }
.crm-value { font-family: 'Bricolage Grotesque', sans-serif; font-size: 26px; font-weight: 700; letter-spacing: -0.5px; }
.crm-sub { font-size: 10px; color: var(--muted); margin-top: 5px; }

/* ── AUDIT MODULE STYLES ── */
.audit-row { display: grid; align-items: center; gap: 0; padding: 11px 16px; border-bottom: 1px solid var(--border); transition: background 0.1s; }
.audit-row:hover { background: rgba(255,255,255,0.02); }
.audit-row.hdr { background: var(--ink3); font-size: 9.5px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); }
.audit-score { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; font-size: 11px; font-weight: 700; }

/* ── COMPLETION MODULE STYLES ── */
.comp-track { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; margin-bottom: 14px; }
.comp-track-header { padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); }
.comp-track-name { font-family: 'Bricolage Grotesque', sans-serif; font-size: 13px; font-weight: 600; }
.comp-track-pct { font-family: 'Bricolage Grotesque', sans-serif; font-size: 18px; font-weight: 700; }
.comp-bar-outer { height: 8px; background: var(--ink3); }
.comp-bar-inner { height: 100%; transition: width 0.8s ease; }

/* ── CONTEXT BAR (Team/BDA selector + Program + sub-section toggles) ── */
.context-bar { background: var(--ink2); border-bottom: 1px solid var(--border); padding: 0 28px; display: flex; align-items: center; gap: 12px; height: 46px; overflow-x: auto; }
.context-bar::-webkit-scrollbar { height: 2px; }
.context-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.2px; white-space: nowrap; }
.context-select { background: var(--ink3); border: 1px solid var(--border2); border-radius: var(--r-sm); padding: 5px 10px; color: var(--text); font-family: 'IBM Plex Mono', monospace; font-size: 11px; outline: none; cursor: pointer; transition: border-color 0.15s; }
.context-select:focus { border-color: var(--accent); }
.context-divider { width: 1px; height: 20px; background: var(--border); margin: 0 4px; }

/* ── SUB-NAV ── */
.sub-nav { background: var(--ink2); border-bottom: 1px solid var(--border); padding: 0 28px; display: flex; align-items: center; gap: 4px; height: 40px; overflow-x: auto; }
.sub-nav::-webkit-scrollbar { height: 2px; }
.sub-nav::-webkit-scrollbar-thumb { background: var(--border2); }
.sub-tab { padding: 4px 14px; border-radius: 20px; font-size: 11px; font-weight: 500; color: var(--muted); cursor: pointer; border: 1px solid transparent; transition: all 0.15s; white-space: nowrap; letter-spacing: 0.3px; }
.sub-tab:hover { color: var(--text); background: var(--ink3); }
.sub-tab.active { color: var(--ink); background: var(--accent); border-color: var(--accent); font-weight: 600; }
.sub-tab.sales-tab { border-color: rgba(200,255,87,0.3); color: var(--accent); }
.sub-tab.sales-tab.active { color: var(--ink); background: var(--accent); }

/* ── FILTERS BAR ── */
.filters-bar { padding: 12px 28px; display: flex; align-items: center; gap: 10px; background: var(--ink); border-bottom: 1px solid var(--border); flex-wrap: wrap; }
.filter-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; margin-right: 4px; }
.filter-select { background: var(--ink2); border: 1px solid var(--border2); border-radius: var(--r-sm); padding: 5px 10px; color: var(--text); font-family: 'IBM Plex Mono', monospace; font-size: 11px; outline: none; cursor: pointer; transition: border-color 0.15s; }
.filter-select:focus { border-color: var(--accent); }
.filter-divider { width: 1px; height: 20px; background: var(--border); margin: 0 6px; }
.filter-btn { padding: 5px 12px; border-radius: var(--r-sm); border: 1px solid var(--border2); background: none; color: var(--muted2); font-family: 'IBM Plex Mono', monospace; font-size: 11px; cursor: pointer; transition: all 0.15s; }
.filter-btn:hover { border-color: var(--accent); color: var(--accent); }
.filter-btn.accent { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }

/* ── API STATUS ── */
.api-status { display: flex; align-items: center; gap: 6px; font-size: 10px; color: var(--muted); background: var(--ink2); border: 1px solid var(--border); border-radius: 20px; padding: 3px 10px; margin-left: auto; cursor: pointer; }
.api-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); }
.api-dot.error { background: var(--coral); }
.api-dot.loading { background: var(--amber); animation: pulse 1s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.3} }

/* ── CANVAS ── */
.canvas { padding: 24px 28px; max-width: 1600px; }

/* ── PAGE HEADER ── */
.page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; }
.page-title { font-family: 'Bricolage Grotesque', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }
.page-title span { color: var(--accent); }
.page-sub { font-size: 11px; color: var(--muted); margin-top: 4px; letter-spacing: 0.3px; }
.last-updated { font-size: 10px; color: var(--muted); background: var(--ink2); border: 1px solid var(--border); padding: 4px 10px; border-radius: 20px; }

/* ── KPI ROW ── */
.kpi-row { display: grid; gap: 12px; margin-bottom: 20px; }
.kpi-row-4 { grid-template-columns: repeat(4, 1fr); }
.kpi-row-5 { grid-template-columns: repeat(5, 1fr); }
.kpi-row-6 { grid-template-columns: repeat(6, 1fr); }
.kpi-card { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); padding: 18px 20px; position: relative; overflow: hidden; transition: border-color 0.2s; }
.kpi-card:hover { border-color: var(--border2); }
.kpi-card.accent-card { border-color: rgba(200,255,87,0.25); background: var(--accent-dim2); }
.kpi-card-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; }
.kpi-card-value { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 700; letter-spacing: -1px; line-height: 1; }
.kpi-card.accent-card .kpi-card-value { color: var(--accent); }
.kpi-card-sub { font-size: 10px; color: var(--muted); margin-top: 6px; }
.kpi-card-delta { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; padding: 2px 7px; border-radius: 20px; margin-top: 6px; }
.kpi-card-delta.up { background: rgba(52,211,153,0.12); color: var(--teal); }
.kpi-card-delta.down { background: rgba(255,107,107,0.12); color: var(--coral); }
.kpi-stripe { position: absolute; bottom: 0; left: 0; right: 0; height: 3px; }

/* ── SECTION ── */
.section { margin-bottom: 20px; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
.section-title { font-family: 'Bricolage Grotesque', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: -0.2px; display: flex; align-items: center; gap: 8px; }
.section-title::before { content: ''; display: block; width: 3px; height: 14px; background: var(--accent); border-radius: 2px; }
.section-badge { font-size: 9px; font-weight: 500; padding: 2px 8px; border-radius: 20px; background: var(--ink3); color: var(--muted2); border: 1px solid var(--border); font-family: 'IBM Plex Mono', monospace; }

/* ── GRIDS ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
.grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; }
.grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: 14px; }

/* ── CHART CARD ── */
.chart-card { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; }
.chart-card-title { font-size: 11px; font-weight: 500; color: var(--muted2); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
.chart-card-title span { font-weight: 400; color: var(--muted); text-transform: none; letter-spacing: 0; font-size: 10px; }

/* ── TABLE ── */
.data-table-wrap { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead tr { background: var(--ink3); }
.data-table th { padding: 10px 14px; text-align: left; font-size: 9.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); white-space: nowrap; border-bottom: 1px solid var(--border); }
.data-table td { padding: 10px 14px; font-size: 12px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: middle; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: rgba(255,255,255,0.02); }
.data-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
.data-table td.highlight { color: var(--accent); font-weight: 600; }
.data-table td.muted { color: var(--muted); }

/* ── PILL ── */
.pill { display: inline-block; padding: 2px 9px; border-radius: 20px; font-size: 10px; font-weight: 500; }
.pill-green { background: rgba(52,211,153,0.15); color: var(--teal); }
.pill-red { background: rgba(255,107,107,0.15); color: var(--coral); }
.pill-blue { background: rgba(74,158,255,0.15); color: var(--blue); }
.pill-amber { background: rgba(251,191,36,0.15); color: var(--amber); }
.pill-purple { background: rgba(167,139,250,0.15); color: var(--purple); }

/* ── FUNNEL ── */
.funnel-wrap { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; }
.funnel-step { display: flex; align-items: center; gap: 16px; margin-bottom: 8px; position: relative; }
.funnel-step:last-child { margin-bottom: 0; }
.funnel-step-bar-wrap { flex: 1; height: 36px; background: var(--ink3); border-radius: var(--r-sm); overflow: hidden; position: relative; cursor: pointer; }
.funnel-step-bar { height: 100%; border-radius: var(--r-sm); display: flex; align-items: center; padding: 0 12px; transition: filter 0.15s; min-width: 60px; }
.funnel-step-bar:hover { filter: brightness(1.1); }
.funnel-step-bar-label { font-size: 11px; font-weight: 600; color: var(--ink); white-space: nowrap; }
.funnel-step-meta { width: 200px; display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
.funnel-step-name { font-size: 11px; font-weight: 500; color: var(--text); }
.funnel-step-drop { font-size: 10px; color: var(--muted); }
.funnel-drop-arrow { font-size: 9px; color: var(--coral); margin: 0 0 0 216px; padding: 2px 0; display: flex; align-items: center; gap: 4px; }

/* ── CHANNEL TABLE ── */
.channel-name-input { background: var(--ink3); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 5px 9px; color: var(--text); font-family: 'IBM Plex Mono', monospace; font-size: 12px; outline: none; width: 150px; transition: border-color 0.15s; }
.channel-name-input:focus { border-color: var(--accent); }
.channel-num-input { background: var(--ink3); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 5px 9px; color: var(--accent); font-family: 'IBM Plex Mono', monospace; font-size: 12px; font-weight: 500; outline: none; width: 90px; text-align: right; transition: border-color 0.15s; }
.channel-num-input:focus { border-color: var(--accent); }
.add-channel-btn { background: var(--accent-dim); border: 1px dashed rgba(200,255,87,0.4); border-radius: var(--r-sm); color: var(--accent); font-family: 'IBM Plex Mono', monospace; font-size: 11px; padding: 6px 14px; cursor: pointer; width: 100%; margin-top: 8px; transition: all 0.15s; }
.add-channel-btn:hover { background: rgba(200,255,87,0.2); }
.del-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 14px; padding: 2px 6px; border-radius: 4px; transition: color 0.15s; }
.del-btn:hover { color: var(--coral); }

/* ── PROGRESS BAR ── */
.prog-bar-wrap { height: 6px; background: var(--ink3); border-radius: 3px; flex: 1; overflow: hidden; }
.prog-bar { height: 100%; border-radius: 3px; transition: width 0.6s ease; }

/* ── HANDOFF CARDS ── */
.handoff-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
.handoff-card { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); padding: 16px 18px; }
.handoff-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.handoff-value { font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: -0.5px; }
.handoff-sub { font-size: 10px; color: var(--muted); margin-top: 4px; }

/* ── INCOME BRACKET ── */
.bracket-row { display: grid; grid-template-columns: 140px 1fr 80px 80px 80px 80px; align-items: center; gap: 12px; padding: 10px 14px; border-bottom: 1px solid var(--border); transition: background 0.1s; }
.bracket-row:hover { background: rgba(255,255,255,0.02); }
.bracket-row.header { background: var(--ink3); font-size: 9.5px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); }

/* ── RATE TABLE ── */
.rate-table-wrap { background: var(--ink2); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.rate-row { display: grid; grid-template-columns: 120px repeat(5, 1fr); align-items: center; gap: 0; padding: 10px 16px; border-bottom: 1px solid var(--border); }
.rate-row:last-child { border-bottom: none; }
.rate-row.hdr { background: var(--ink3); font-size: 9.5px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); }
.rate-val { font-size: 12px; font-variant-numeric: tabular-nums; }
.rate-pct { display: flex; align-items: center; gap: 6px; }
.rate-pct .bar { flex: 1; }

/* ── VIEW PANELS ── */
.view-panel { display: none; animation: fadeUp 0.2s ease; }
.view-panel.active { display: block; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

/* ── ARPU SECTION PANELS ── */
.arpu-panel { display: none; }
.arpu-panel.active { display: block; }

/* ── SUMMARY STRIP ── */
.summary-strip { background: var(--accent-dim2); border: 1px solid rgba(200,255,87,0.15); border-radius: var(--r); padding: 12px 20px; display: flex; align-items: center; gap: 32px; margin-bottom: 20px; flex-wrap: wrap; }
.summary-item-label { font-size: 9.5px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
.summary-item-val { font-family: 'Bricolage Grotesque', sans-serif; font-size: 20px; font-weight: 700; color: var(--accent); letter-spacing: -0.5px; margin-top: 2px; }

/* ── L2P ── */
.l2p-badge { font-family: 'Bricolage Grotesque', sans-serif; font-size: 32px; font-weight: 800; letter-spacing: -1px; color: var(--accent); }
.l2p-sub { font-size: 10px; color: var(--muted); margin-top: 4px; }

/* ── API CONFIG MODAL ── */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; display: none; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal { background: var(--ink2); border: 1px solid var(--border2); border-radius: 14px; padding: 28px; width: 520px; max-width: 90vw; }
.modal-title { font-family: 'Bricolage Grotesque', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px; }
.modal-sub { font-size: 11px; color: var(--muted); margin-bottom: 20px; }
.modal-field { margin-bottom: 14px; }
.modal-field label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.2px; display: block; margin-bottom: 6px; }
.modal-input { background: var(--ink3); border: 1px solid var(--border2); border-radius: var(--r-sm); padding: 8px 12px; color: var(--text); font-family: 'IBM Plex Mono', monospace; font-size: 12px; outline: none; width: 100%; transition: border-color 0.15s; }
.modal-input:focus { border-color: var(--accent); }
.modal-row { display: flex; gap: 10px; margin-top: 16px; }
.modal-btn { flex: 1; padding: 9px; border-radius: var(--r-sm); font-family: 'IBM Plex Mono', monospace; font-size: 12px; cursor: pointer; font-weight: 600; transition: all 0.15s; }
.modal-btn.primary { background: var(--accent); border: none; color: var(--ink); }
.modal-btn.primary:hover { background: #d4ff6a; }
.modal-btn.secondary { background: none; border: 1px solid var(--border2); color: var(--muted2); }
.modal-btn.secondary:hover { border-color: var(--text); color: var(--text); }
.api-info-box { background: var(--ink3); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 12px; margin-bottom: 16px; font-size: 10px; color: var(--muted); line-height: 1.6; }
.api-info-box strong { color: var(--muted2); }

/* ── PIPELINE STAGE BADGE ── */
.stage-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 9px; padding: 2px 8px; border-radius: 20px; background: var(--ink3); border: 1px solid var(--border); color: var(--muted2); }

/* ── RESPONSIVE ── */
@media (max-width: 1200px) {
  .kpi-row-4 { grid-template-columns: repeat(2, 1fr); }
  .kpi-row-5 { grid-template-columns: repeat(3, 1fr); }
  .kpi-row-6 { grid-template-columns: repeat(3, 1fr); }
  .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }
  .handoff-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<!-- API CONFIG MODAL -->
<div class="modal-overlay" id="apiModal">
  <div class="modal">
    <div class="modal-title">API Configuration</div>
    <div class="modal-sub">Connect to Scaler CRM to pull live data</div>
    <div class="api-info-box">
      <strong>How it works:</strong> Configure your API endpoint and auth token below. The dashboard will fetch data from your CRM on load and on each refresh. Currently showing <strong>demo data</strong> — connect an API to get live numbers.<br><br>
      <strong>Expected endpoint:</strong> POST /api/v1/dashboard/metrics<br>
      <strong>Expected response:</strong> JSON with funnel, channels, income, batch, experience, sources, handoff, sales keys
    </div>
    <div class="modal-field">
      <label>API Base URL</label>
      <input class="modal-input" id="apiUrl" placeholder="https://crm.scaler.com/api/v1" />
    </div>
    <div class="modal-field">
      <label>Auth Token (Bearer)</label>
      <input class="modal-input" id="apiToken" type="password" placeholder="eyJ..." />
    </div>
    <div class="modal-field">
      <label>Team ID</label>
      <input class="modal-input" id="apiTeamId" placeholder="team_aayush" />
    </div>
    <div style="font-size:10px;color:var(--muted);margin-bottom:4px;">
      ⚠ CORS must be enabled on your API server for browser-based calls to work.
    </div>
    <div class="modal-row">
      <button class="modal-btn primary" onclick="saveApiConfig()">Save & Test Connection</button>
      <button class="modal-btn secondary" onclick="closeApiModal()">Use Demo Data</button>
    </div>
  </div>
</div>

<!-- SECTION NAV -->
<nav class="section-nav">
  <div class="section-nav-brand">Team Aayush <span>Scaler</span></div>
  <div class="section-tab s-marketing active" id="stab-marketing" onclick="switchSection('marketing',this)"><span class="section-tab-icon">📈</span> Marketing</div>
  <div class="section-tab s-crm" id="stab-crm" onclick="switchSection('crm',this)"><span class="section-tab-icon">🗂</span> CRM</div>
  <div class="section-tab s-audit" id="stab-audit" onclick="switchSection('audit',this)"><span class="section-tab-icon">🔍</span> Audit</div>
  <div class="section-tab s-completion" id="stab-completion" onclick="switchSection('completion',this)"><span class="section-tab-icon">✅</span> Completion</div>
  <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">
    <div class="api-status" onclick="openApiModal()" title="Configure API connection">
      <div class="api-dot" id="apiDot"></div>
      <span id="apiStatusText">Demo Mode</span>
    </div>
  </div>
</nav>

<!-- ══ MARKETING SECTION ══ -->
<div id="section-marketing">

<!-- TOP NAV (ARPU tabs) -->
<nav class="top-nav" style="top:44px;">
  <div class="main-tab active" id="tab-mid" onclick="switchArpu('mid',this)">Mid ARPU</div>
  <div class="main-tab" id="tab-high" onclick="switchArpu('high',this)">High ARPU</div>
  <div class="main-tab" id="tab-low-up" onclick="switchArpu('lowup',this)">Low ARPU <span style="font-size:9px;margin-left:4px;background:var(--ink3);padding:1px 5px;border-radius:4px;color:var(--muted);">Upselling</span></div>
  <div class="main-tab" id="tab-low-fresh" onclick="switchArpu('lowfresh',this)">Low ARPU <span style="font-size:9px;margin-left:4px;background:var(--ink3);padding:1px 5px;border-radius:4px;color:var(--muted);">Freshselling</span></div>
</nav>

<!-- CONTEXT BAR -->
<div class="context-bar" id="contextBar">
  <!-- populated dynamically per ARPU section -->
</div>

<!-- SUB-NAV -->
<div class="sub-nav" id="subNav">
  <!-- populated dynamically per ARPU section -->
</div>

<!-- FILTERS -->
<div class="filters-bar">
  <span class="filter-label">Period</span>
  <select class="filter-select" id="periodFilter" onchange="handlePeriodChange()">
    <option value="mtd">MTD</option>
    <option value="last7">Last 7 days</option>
    <option value="last30">Last 30 days</option>
    <option value="q1">Q1 2025</option>
    <option value="q2">Q2 2025</option>
    <option value="fy">Full Year 2025</option>
    <option value="custom">Custom Date Range</option>
  </select>
  <div id="custom-date-wrap" style="display:none;align-items:center;gap:6px;">
    <input type="date" class="filter-select" id="customFrom" onchange="refreshAll()" style="padding:4px 8px;" />
    <span style="color:var(--muted);font-size:11px;">→</span>
    <input type="date" class="filter-select" id="customTo" onchange="refreshAll()" style="padding:4px 8px;" />
  </div>
  <div class="filter-divider"></div>
  <span class="filter-label">Program</span>
  <select class="filter-select" id="programFilter" onchange="refreshAll()">
    <!-- populated per ARPU section -->
  </select>
  <div class="filter-divider"></div>
  <button class="filter-btn accent" onclick="fetchAndRefresh()">↻ Refresh</button>
  <button class="filter-btn" onclick="exportData()">⬇ Export</button>
</div>

<!-- MAIN CANVAS -->
<div class="canvas" id="mainCanvas">
  <!-- Rendered dynamically -->
</div>

</div><!-- /section-marketing -->

<!-- ══ CRM SECTION ══ -->
<div id="section-crm" style="display:none;">
  <div style="background:var(--ink2);border-bottom:1px solid var(--border);padding:0 28px;height:48px;display:flex;align-items:center;gap:4px;position:sticky;top:44px;z-index:49;">
    <div class="sub-tab active" id="crm-tab-overview" onclick="switchCrmTab('overview',this)">Overview</div>
    <div class="sub-tab" id="crm-tab-leads" onclick="switchCrmTab('leads',this)">Lead Register</div>
    <div class="sub-tab" id="crm-tab-pipeline" onclick="switchCrmTab('pipeline',this)">Pipeline</div>
    <div class="sub-tab" id="crm-tab-followups" onclick="switchCrmTab('followups',this)">Follow-ups</div>
    <div class="sub-tab" id="crm-tab-lost" onclick="switchCrmTab('lost',this)">Lost / Dropped</div>
  </div>
  <div class="canvas" id="crm-canvas"></div>
</div>

<!-- ══ AUDIT SECTION ══ -->
<div id="section-audit" style="display:none;">
  <div style="background:var(--ink2);border-bottom:1px solid var(--border);padding:0 28px;height:48px;display:flex;align-items:center;gap:4px;position:sticky;top:44px;z-index:49;">
    <div class="sub-tab active" id="audit-tab-calls" onclick="switchAuditTab('calls',this)">Call Audits</div>
    <div class="sub-tab" id="audit-tab-bda" onclick="switchAuditTab('bda',this)">BDA Scores</div>
    <div class="sub-tab" id="audit-tab-flags" onclick="switchAuditTab('flags',this)">Flagged Calls</div>
    <div class="sub-tab" id="audit-tab-trends" onclick="switchAuditTab('trends',this)">Score Trends</div>
  </div>
  <div class="canvas" id="audit-canvas"></div>
</div>

<!-- ══ COMPLETION SECTION ══ -->
<div id="section-completion" style="display:none;">
  <div style="background:var(--ink2);border-bottom:1px solid var(--border);padding:0 28px;height:48px;display:flex;align-items:center;gap:4px;position:sticky;top:44px;z-index:49;">
    <div class="sub-tab active" id="comp-tab-overview" onclick="switchCompTab('overview',this)">Overview</div>
    <div class="sub-tab" id="comp-tab-cohort" onclick="switchCompTab('cohort',this)">Cohort Wise</div>
    <div class="sub-tab" id="comp-tab-program" onclick="switchCompTab('program',this)">Program Wise</div>
    <div class="sub-tab" id="comp-tab-risk" onclick="switchCompTab('risk',this)">At Risk</div>
  </div>
  <div class="canvas" id="comp-canvas"></div>
</div>

