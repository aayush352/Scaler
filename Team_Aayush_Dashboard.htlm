// ═══════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════
const CLRS = ['#c8ff57','#4a9eff','#a78bfa','#ff6b6b','#fbbf24','#34d399','#f472b6'];
function periodMul() {
  const p = document.getElementById('periodFilter').value;
  return { mtd:1, last7:0.23, last30:0.87, q1:2.9, q2:3.1, fy:12 }[p] || 1;
}
function scl(n) { return Math.round(n * periodMul()); }
function pct(a,b) { return b ? (a/b*100).toFixed(1)+'%' : '—'; }
function fmt(n) { if(n>=100000) return (n/100000).toFixed(1)+'L'; if(n>=1000) return (n/1000).toFixed(1)+'K'; return n; }
function destroyChart(id) { if(_charts[id]) { _charts[id].destroy(); delete _charts[id]; } }
Chart.defaults.color = '#6b6b88';
Chart.defaults.font.family = 'IBM Plex Mono';
Chart.defaults.font.size = 10;

// ═══════════════════════════════════════════════════════
// API LAYER
// ═══════════════════════════════════════════════════════
function openApiModal() {
  document.getElementById('apiUrl').value = API_CONFIG.url;
  document.getElementById('apiToken').value = API_CONFIG.token;
  document.getElementById('apiTeamId').value = API_CONFIG.teamId;
  document.getElementById('apiModal').classList.add('active');
}
function closeApiModal() { document.getElementById('apiModal').classList.remove('active'); }
function saveApiConfig() {
  API_CONFIG.url = document.getElementById('apiUrl').value.trim();
  API_CONFIG.token = document.getElementById('apiToken').value.trim();
  API_CONFIG.teamId = document.getElementById('apiTeamId').value.trim();
  closeApiModal();
  if (API_CONFIG.url) fetchAndRefresh();
}

async function fetchFromAPI(endpoint, params = {}) {
  if (!API_CONFIG.url) return null;
  const dot = document.getElementById('apiDot');
  const statusText = document.getElementById('apiStatusText');
  dot.className = 'api-dot loading';
  statusText.textContent = 'Fetching...';
  try {
    const url = new URL(endpoint, API_CONFIG.url);
    Object.entries(params).forEach(([k,v]) => url.searchParams.set(k,v));
    const resp = await fetch(url.toString(), {
      headers: {
        'Authorization': `Bearer ${API_CONFIG.token}`,
        'Content-Type': 'application/json',
        'X-Team-ID': API_CONFIG.teamId
      }
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const data = await resp.json();
    dot.className = 'api-dot';
    statusText.textContent = 'Live Data';
    return data;
  } catch(e) {
    dot.className = 'api-dot error';
    statusText.textContent = 'API Error';
    console.warn('API fetch failed, using demo data:', e.message);
    return null;
  }
}

async function fetchAndRefresh() {
  const period = document.getElementById('periodFilter').value;
  const program = document.getElementById('programFilter').value;
  const params = { period, program, team: currentTeam, bda: currentBda, arpu: currentArpu };

  // Try API; fall back to demo
  const liveData = await fetchFromAPI('/dashboard/metrics', params);
  if (liveData) {
    // Merge live data into DEMO object
    if (liveData.funnel) Object.assign(DEMO.funnel, liveData.funnel);
    if (liveData.channels) DEMO.channels = liveData.channels;
    if (liveData.income) DEMO.income = liveData.income;
    if (liveData.batch) DEMO.batch = liveData.batch;
    if (liveData.experience) DEMO.experience = liveData.experience;
    if (liveData.sources) DEMO.sources = liveData.sources;
    if (liveData.handoff) Object.assign(DEMO.handoff, liveData.handoff);
    if (liveData.sales) Object.assign(DEMO.sales, liveData.sales);
  }
  renderCurrentView();
}

// ═══════════════════════════════════════════════════════
// ARPU SECTION SWITCH
// ═══════════════════════════════════════════════════════
function switchArpu(arpu, el) {
  currentArpu = arpu;
  document.querySelectorAll('.main-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const cfg = ARPU_CONFIG[arpu];
  // Rebuild program selector
  const ps = document.getElementById('programFilter');
  ps.innerHTML = cfg.programs.map((p,i) => `<option value="${cfg.programKeys[i]}">${p}</option>`).join('');
  // Set default view for arpu
  currentView = cfg.views[0];
  buildContextBar();
  buildSubNav();
  buildCanvas();
  renderCurrentView();
}

// ═══════════════════════════════════════════════════════
// CONTEXT BAR (Team + BDA selectors)
// ═══════════════════════════════════════════════════════
function buildContextBar() {
  const bar = document.getElementById('contextBar');
  const teamOptions = Object.entries(TEAMS).map(([k,v]) =>
    `<option value="${k}">${v.label}</option>`).join('');
  bar.innerHTML = `
    <span class="context-label">Team</span>
    <select class="context-select" id="teamFilter" onchange="handleTeamChange()">
      ${teamOptions}
    </select>
    <div class="context-divider"></div>
    <span class="context-label">BDA</span>
    <select class="context-select" id="bdaFilter" onchange="handleBdaChange()">
      <option value="all">All BDAs</option>
    </select>
    <div class="context-divider"></div>
    <span style="font-size:10px;color:var(--muted);">Viewing: <span style="color:var(--accent);" id="contextLabel">${ARPU_CONFIG[currentArpu].label}</span></span>
  `;
}

function handleTeamChange() {
  currentTeam = document.getElementById('teamFilter').value;
  currentBda = 'all';
  const bdaSelect = document.getElementById('bdaFilter');
  const team = TEAMS[currentTeam];
  if (currentTeam === 'all') {
    bdaSelect.innerHTML = '<option value="all">All BDAs</option>';
  } else {
    bdaSelect.innerHTML = '<option value="all">All BDAs</option>' +
      team.bdas.map(b => `<option value="${b}">${b}</option>`).join('');
  }
  fetchAndRefresh();
}

function handleBdaChange() {
  currentBda = document.getElementById('bdaFilter').value;
  fetchAndRefresh();
}

// ═══════════════════════════════════════════════════════
// SUB-NAV
// ═══════════════════════════════════════════════════════
function buildSubNav() {
  const cfg = ARPU_CONFIG[currentArpu];
  const nav = document.getElementById('subNav');
  nav.innerHTML = cfg.views.map((v,i) => {
    const isSales = v === 'sales';
    return `<div class="sub-tab ${isSales ? 'sales-tab' : ''} ${v === currentView ? 'active' : ''}"
      onclick="switchView('${v}', this)">${cfg.viewLabels[i]}</div>`;
  }).join('');
  // High ARPU note
  if (currentArpu === 'high') {
    nav.insertAdjacentHTML('beforeend',
      `<span style="font-size:10px;color:var(--muted);margin-left:12px;align-self:center;">
        Marketing tab coming soon</span>`);
  }
}

// ═══════════════════════════════════════════════════════
// CANVAS BUILDER
// ═══════════════════════════════════════════════════════
function buildCanvas() {
  const cfg = ARPU_CONFIG[currentArpu];
  const canvas = document.getElementById('mainCanvas');
  // Build panels for each view
  canvas.innerHTML = cfg.views.map(v => `<div class="view-panel ${v === currentView ? 'active' : ''}" id="view-${currentArpu}-${v}"></div>`).join('');
}

// ═══════════════════════════════════════════════════════
// VIEW SWITCH
// ═══════════════════════════════════════════════════════
function switchView(view, el) {
  currentView = view;
  document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
  const panel = document.getElementById(`view-${currentArpu}-${view}`);
  if (panel) panel.classList.add('active');
  if (el) el.classList.add('active');
  // Keep sales-tab style if sales
  if (view === 'sales' && el) el.classList.add('sales-tab');
  renderCurrentView();
}

function renderCurrentView() {
  const map = {
    funnel: renderFunnel,
    income: renderIncome,
    batch: renderBatch,
    experience: renderExperience,
    source: renderSource,
    handoff: renderHandoff,
    sales: renderSales
  };
  if (map[currentView]) map[currentView]();
}

function getPanelEl() {
  return document.getElementById(`view-${currentArpu}-${currentView}`);
}

// ═══════════════════════════════════════════════════════
// FILTER HELPERS
// ═══════════════════════════════════════════════════════
function getFilteredTeamData(rawTeam) {
  let data = rawTeam;
  if (currentTeam !== 'all') data = data.filter(r => r.team === currentTeam);
  if (currentBda !== 'all') data = data.filter(r => r.name === currentBda);
  return data;
}

// ═══════════════════════════════════════════════════════
// VIEW: FUNNEL
// ═══════════════════════════════════════════════════════
function renderFunnel() {
  const el = getPanelEl(); if (!el) return;
  const isHigh = currentArpu === 'high';
  const d = DEMO.funnel;
  const gen = scl(d.totalGenerated), cons = scl(d.totalConsumed), sales = scl(d.salesClosed);
  const pipelines = scl(d.pipelines);
  const l2p = ((pipelines / cons) * 100).toFixed(1);

  el.innerHTML = `
    <div class="page-header">
      <div>
        <div class="page-title">Funnel <span>View</span></div>
        <div class="page-sub">Marketing funnel — from lead generation to pipeline conversion · ${ARPU_CONFIG[currentArpu].label}</div>
      </div>
      <div class="last-updated">Last updated: today, 09:14 AM</div>
    </div>
    <div class="summary-strip">
      <div><div class="summary-item-label">Total Leads Generated</div><div class="summary-item-val" id="f-total-gen">${fmt(gen)}</div></div>
      <div><div class="summary-item-label">Total Leads Consumed</div><div class="summary-item-val" id="f-total-consumed">${fmt(cons)}</div></div>
      <div><div class="summary-item-label">Sales Closed</div><div class="summary-item-val" id="f-total-sales">${fmt(sales)}</div></div>
      <div><div class="summary-item-label">L2P (Lead to Pipeline %)</div><div class="summary-item-val" id="f-l2p">${l2p}%</div></div>
    </div>
    <div class="grid-2-1" style="margin-bottom:20px">
      <div class="funnel-wrap">
        <div class="chart-card-title">FULL FUNNEL <span>Step-by-step conversion</span></div>
        <div id="f-funnel-steps"></div>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="chart-card" style="flex:1">
          <div class="chart-card-title">L2P RATE <span>Lead → Pipeline</span></div>
          <div style="display:flex;align-items:center;justify-content:center;height:120px;flex-direction:column;gap:6px;">
            <div class="l2p-badge">${l2p}%</div>
            <div class="l2p-sub">Leads consumed → pipeline formed</div>
          </div>
        </div>
        <div class="chart-card" style="flex:1">
          <div class="chart-card-title">CHANNEL SPLIT <span>Leads generated</span></div>
          <canvas id="f-channelDonut" height="110"></canvas>
        </div>
      </div>
    </div>
    <div class="section">
      <div class="section-header">
        <div class="section-title">Channel-wise Breakdown <span class="section-badge" id="f-channel-count">${DEMO.channels.length} channels</span></div>
        <button class="filter-btn" onclick="addChannel()">+ Add Channel</button>
      </div>
      <div class="data-table-wrap">
        <div style="padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);display:grid;grid-template-columns:160px 1fr 100px 100px 100px 100px 80px;gap:8px;font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Channel Name</span><span>Leads Generated</span><span>Consumed</span><span>Sales</span><span>L2P %</span><span>% of Total</span><span></span>
        </div>
        <div id="f-channel-rows"></div>
        <div style="padding:10px 14px;border-top:1px solid var(--border);">
          <button class="add-channel-btn" onclick="addChannel()">+ Add Channel</button>
        </div>
      </div>
    </div>
    <div class="chart-card">
      <div class="chart-card-title">LEAD GENERATION TREND <span>by channel, monthly</span></div>
      <canvas id="f-funnelTrend" height="90"></canvas>
    </div>
  `;

  // Funnel steps
  const steps = d.steps.map(s => ({ ...s, value: scl(s.value) }));
  const maxV = steps[0].value;
  const colors = ['#c8ff57','#4a9eff','#a78bfa','#fbbf24','#34d399','#f472b6','#ff6b6b','#38bdf8'];
  const stepsEl = document.getElementById('f-funnel-steps');
  stepsEl.innerHTML = '';
  steps.forEach((s, i) => {
    const w = Math.max(20, Math.round(s.value / maxV * 100));
    const drop = i > 0 ? (((steps[i-1].value - s.value) / steps[i-1].value) * 100).toFixed(1) : null;
    if (drop !== null) {
      stepsEl.insertAdjacentHTML('beforeend', `<div class="funnel-drop-arrow">↓ ${drop}% drop</div>`);
    }
    stepsEl.insertAdjacentHTML('beforeend', `
      <div class="funnel-step">
        <div class="funnel-step-meta">
          <div class="funnel-step-name">${s.name}</div>
          <div class="funnel-step-drop">${fmt(s.value)} ${i > 0 ? '(' + pct(s.value, steps[i-1].value) + ')' : '(100%)'}</div>
        </div>
        <div class="funnel-step-bar-wrap">
          <div class="funnel-step-bar" style="width:${w}%;background:${colors[i]}22;border-left:3px solid ${colors[i]};">
            <span class="funnel-step-bar-label" style="color:${colors[i]}">${fmt(s.value)}</span>
          </div>
        </div>
      </div>`);
  });

  // Channel donut
  destroyChart('f-channelDonut');
  _charts['f-channelDonut'] = new Chart(document.getElementById('f-channelDonut'), {
    type: 'doughnut',
    data: { labels: DEMO.channels.map(c => c.name), datasets: [{ data: DEMO.channels.map(c => scl(c.gen)), backgroundColor: CLRS, borderWidth: 0, hoverOffset: 4 }] },
    options: { responsive: true, cutout: '65%', plugins: { legend: { position: 'right', labels: { font: { size: 10 }, boxWidth: 10, padding: 8 } } } }
  });

  // Trend
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const baseGen = [280,310,340,290,380,420,360,400,450,380,410,440];
  destroyChart('f-funnelTrend');
  _charts['f-funnelTrend'] = new Chart(document.getElementById('f-funnelTrend'), {
    type: 'line',
    data: { labels: months, datasets: [
      { label: 'Leads Gen', data: baseGen, borderColor: '#c8ff57', backgroundColor: 'rgba(200,255,87,0.06)', tension: 0.4, fill: true, pointRadius: 3 },
      { label: 'Consumed', data: baseGen.map(v => Math.round(v * 0.7)), borderColor: '#4a9eff', backgroundColor: 'rgba(74,158,255,0.05)', tension: 0.4, fill: true, pointRadius: 3 },
      { label: 'Sales', data: baseGen.map(v => Math.round(v * 0.065)), borderColor: '#34d399', tension: 0.4, pointRadius: 3 }
    ]},
    options: { responsive: true, plugins: { legend: { position: 'top' } }, scales: { x: { grid: { color: 'rgba(255,255,255,0.04)' } }, y: { grid: { color: 'rgba(255,255,255,0.04)' } } } }
  });

  renderChannelTable();
}

function renderChannelTable() {
  const rows = DEMO.channels;
  const totalGen = rows.reduce((s,r) => s + scl(r.gen), 0);
  const countEl = document.getElementById('f-channel-count');
  if (countEl) countEl.textContent = rows.length + ' channels';
  const rowsEl = document.getElementById('f-channel-rows');
  if (!rowsEl) return;
  rowsEl.innerHTML = rows.map((r,i) => {
    const gen = scl(r.gen), cons = scl(r.consumed), sales = scl(r.sales);
    const pctOfTotal = ((gen/totalGen)*100).toFixed(1)+'%';
    return `<div style="display:grid;grid-template-columns:160px 1fr 100px 100px 100px 100px 80px;gap:8px;align-items:center;padding:9px 14px;border-bottom:1px solid var(--border);">
      <input class="channel-name-input" value="${r.name}" onchange="DEMO.channels[${i}].name=this.value;renderChannelTable()" />
      <div style="display:flex;align-items:center;gap:10px;">
        <input class="channel-num-input" type="number" value="${gen}" onchange="DEMO.channels[${i}].gen=Math.round(+this.value/periodMul());renderFunnel()" />
        <div class="prog-bar-wrap"><div class="prog-bar" style="width:${Math.round(gen/totalGen*100)}%;background:${CLRS[i%CLRS.length]};"></div></div>
      </div>
      <input class="channel-num-input" type="number" value="${cons}" onchange="DEMO.channels[${i}].consumed=Math.round(+this.value/periodMul());renderFunnel()" />
      <input class="channel-num-input" type="number" value="${sales}" onchange="DEMO.channels[${i}].sales=Math.round(+this.value/periodMul());renderFunnel()" />
      <span style="color:var(--accent);font-weight:600;">${pct(cons, gen)}</span>
      <span style="color:var(--muted2);">${pctOfTotal}</span>
      <button class="del-btn" onclick="DEMO.channels.splice(${i},1);renderFunnel()">✕</button>
    </div>`;
  }).join('');
}

function addChannel() {
  DEMO.channels.push({ name: 'New Channel', gen: 0, consumed: 0, sales: 0 });
  renderChannelTable();
  setTimeout(() => { const inputs = document.querySelectorAll('.channel-name-input'); inputs[inputs.length-1]?.focus(); inputs[inputs.length-1]?.select(); }, 50);
}

// ═══════════════════════════════════════════════════════
// VIEW: INCOME BRACKET
// ═══════════════════════════════════════════════════════
function renderIncome() {
  const el = getPanelEl(); if (!el) return;
  const data = DEMO.income;
  const totGen = data.reduce((s,r) => s+scl(r.gen), 0);
  const totCons = data.reduce((s,r) => s+scl(r.consumed), 0);
  const totSales = data.reduce((s,r) => s+scl(r.sales), 0);
  const totPipe = Math.round(totCons * 0.302);

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Income <span>Bracket View</span></div>
      <div class="page-sub">Lead and sales performance segmented by monthly income bracket · ${ARPU_CONFIG[currentArpu].label}</div></div>
    </div>
    <div class="summary-strip">
      <div><div class="summary-item-label">Total Leads Generated</div><div class="summary-item-val">${fmt(totGen)}</div></div>
      <div><div class="summary-item-label">Total Leads Consumed</div><div class="summary-item-val">${fmt(totCons)}</div></div>
      <div><div class="summary-item-label">Sales Closed</div><div class="summary-item-val">${fmt(totSales)}</div></div>
      <div><div class="summary-item-label">L2P Rate</div><div class="summary-item-val">${pct(totPipe, totCons)}</div></div>
    </div>
    <div class="grid-2" style="margin-bottom:20px;">
      <div class="chart-card"><div class="chart-card-title">LEADS BY INCOME BRACKET</div><canvas id="ib-bar" height="160"></canvas></div>
      <div class="chart-card"><div class="chart-card-title">SALES CLOSED BY BRACKET</div><canvas id="ib-sales" height="160"></canvas></div>
    </div>
    <div class="data-table-wrap">
      <div class="bracket-row header"><span>Income Bracket</span><span>Leads Generated</span><span>Consumed</span><span>Sales</span><span>L2P %</span><span>Conv %</span></div>
      ${data.map((r,i) => {
        const gen=scl(r.gen),cons=scl(r.consumed),sales=scl(r.sales),pipe=Math.round(cons*0.302);
        return `<div class="bracket-row">
          <span style="color:${CLRS[i]};font-weight:500;">${r.bracket}</span>
          <div style="display:flex;align-items:center;gap:10px;"><span>${fmt(gen)}</span><div class="prog-bar-wrap"><div class="prog-bar" style="width:${Math.round(gen/totGen*100)}%;background:${CLRS[i]};"></div></div></div>
          <span style="color:var(--muted2);">${fmt(cons)}</span>
          <span style="color:var(--accent);font-weight:600;">${fmt(sales)}</span>
          <span style="color:var(--teal);">${pct(pipe,cons)}</span>
          <span style="color:var(--blue);">${pct(sales,cons)}</span>
        </div>`;
      }).join('')}
    </div>`;

  destroyChart('ib-bar');
  _charts['ib-bar'] = new Chart(document.getElementById('ib-bar'), {
    type:'bar', data:{ labels: data.map(r=>r.bracket), datasets:[
      {label:'Generated',data:data.map(r=>scl(r.gen)),backgroundColor:'rgba(200,255,87,0.6)',borderRadius:3},
      {label:'Consumed',data:data.map(r=>scl(r.consumed)),backgroundColor:'rgba(74,158,255,0.6)',borderRadius:3},
    ]},
    options:{responsive:true,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
  destroyChart('ib-sales');
  _charts['ib-sales'] = new Chart(document.getElementById('ib-sales'), {
    type:'bar', data:{ labels: data.map(r=>r.bracket), datasets:[{label:'Sales',data:data.map(r=>scl(r.sales)),backgroundColor:CLRS,borderRadius:3}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
}

// ═══════════════════════════════════════════════════════
// VIEW: BATCH
// ═══════════════════════════════════════════════════════
function renderBatch() {
  const el = getPanelEl(); if (!el) return;
  const data = DEMO.batch;
  const totGen=data.reduce((s,r)=>s+scl(r.gen),0);
  const totCons=data.reduce((s,r)=>s+scl(r.consumed),0);
  const totSales=data.reduce((s,r)=>s+scl(r.sales),0);
  const totPipe=Math.round(totCons*0.302);
  const batchColors=['#4a9eff','#fbbf24','#a78bfa'];

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Batch <span>Wise View</span></div>
      <div class="page-sub">Lead quality and conversion by batch complexity · ${ARPU_CONFIG[currentArpu].label}</div></div>
    </div>
    <div class="summary-strip">
      <div><div class="summary-item-label">Total Leads Generated</div><div class="summary-item-val">${fmt(totGen)}</div></div>
      <div><div class="summary-item-label">Total Leads Consumed</div><div class="summary-item-val">${fmt(totCons)}</div></div>
      <div><div class="summary-item-label">Sales Closed</div><div class="summary-item-val">${fmt(totSales)}</div></div>
      <div><div class="summary-item-label">L2P Rate</div><div class="summary-item-val">${pct(totPipe,totCons)}</div></div>
    </div>
    <div class="grid-3" style="margin-bottom:20px;">
      ${data.map((r,i)=>`<div class="kpi-card" style="border-color:${batchColors[i]}4d;background:${batchColors[i]}11;">
        <div class="kpi-card-label">${r.level} Batch</div>
        <div class="kpi-card-value" style="color:${batchColors[i]};">${fmt(scl(r.gen))}</div>
        <div class="kpi-card-sub">Leads generated</div>
        <div class="kpi-stripe" style="background:${batchColors[i]};"></div>
      </div>`).join('')}
    </div>
    <div class="grid-2" style="margin-bottom:20px;">
      <div class="chart-card"><div class="chart-card-title">LEADS BY BATCH</div><canvas id="bw-bar" height="160"></canvas></div>
      <div class="chart-card"><div class="chart-card-title">L2P % BY BATCH</div><canvas id="bw-l2p" height="160"></canvas></div>
    </div>
    <div class="data-table-wrap">
      <div style="display:grid;grid-template-columns:130px 110px 110px 100px 100px 100px;padding:10px 14px;background:var(--ink3);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);border-bottom:1px solid var(--border);">
        <span>Batch Level</span><span>Leads Gen.</span><span>Consumed</span><span>Sales</span><span>L2P %</span><span>Closure %</span>
      </div>
      ${data.map((r,i)=>{const gen=scl(r.gen),cons=scl(r.consumed),sales=scl(r.sales),pipe=Math.round(cons*0.302);
        return `<div style="display:grid;grid-template-columns:130px 110px 110px 100px 100px 100px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;">
          <span style="color:${batchColors[i]};font-weight:500;">${r.level}</span>
          <span>${fmt(gen)}</span><span style="color:var(--muted2);">${fmt(cons)}</span>
          <span style="color:var(--accent);font-weight:600;">${fmt(sales)}</span>
          <span style="color:var(--teal);">${pct(pipe,cons)}</span>
          <span style="color:var(--blue);">${pct(sales,cons)}</span>
        </div>`;}).join('')}
    </div>`;

  destroyChart('bw-bar');
  _charts['bw-bar'] = new Chart(document.getElementById('bw-bar'),{
    type:'bar',data:{labels:data.map(r=>r.level),datasets:[
      {label:'Generated',data:data.map(r=>scl(r.gen)),backgroundColor:batchColors.map(c=>c+'99'),borderRadius:3},
      {label:'Consumed',data:data.map(r=>scl(r.consumed)),backgroundColor:batchColors.map(c=>c+'55'),borderRadius:3},
    ]},
    options:{responsive:true,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
  destroyChart('bw-l2p');
  _charts['bw-l2p'] = new Chart(document.getElementById('bw-l2p'),{
    type:'bar',data:{labels:data.map(r=>r.level),datasets:[{label:'L2P %',data:data.map(r=>(Math.round(scl(r.consumed)*0.302)/scl(r.consumed)*100).toFixed(1)),backgroundColor:batchColors,borderRadius:3}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{max:50,ticks:{callback:v=>v+'%'},grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
}

// ═══════════════════════════════════════════════════════
// VIEW: EXPERIENCE
// ═══════════════════════════════════════════════════════
function renderExperience() {
  const el = getPanelEl(); if (!el) return;
  const data = DEMO.experience;
  const totGen=data.reduce((s,r)=>s+scl(r.gen),0);
  const totCons=data.reduce((s,r)=>s+scl(r.consumed),0);
  const totSales=data.reduce((s,r)=>s+scl(r.sales),0);
  const totPipe=Math.round(totCons*0.302);
  const expColors=['#34d399','#4a9eff','#a78bfa'];

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Experience <span>Level View</span></div>
      <div class="page-sub">Funnel metrics by learner's prior experience level · ${ARPU_CONFIG[currentArpu].label}</div></div>
    </div>
    <div class="summary-strip">
      <div><div class="summary-item-label">Total Leads Generated</div><div class="summary-item-val">${fmt(totGen)}</div></div>
      <div><div class="summary-item-label">Total Leads Consumed</div><div class="summary-item-val">${fmt(totCons)}</div></div>
      <div><div class="summary-item-label">Sales Closed</div><div class="summary-item-val">${fmt(totSales)}</div></div>
      <div><div class="summary-item-label">L2P Rate</div><div class="summary-item-val">${pct(totPipe,totCons)}</div></div>
    </div>
    <div class="grid-3" style="margin-bottom:20px;">
      ${data.map((r,i)=>`<div class="kpi-card" style="border-color:${expColors[i]}4d;background:${expColors[i]}11;">
        <div class="kpi-card-label">${r.level}</div>
        <div class="kpi-card-value" style="color:${expColors[i]};">${fmt(scl(r.gen))}</div>
        <div class="kpi-card-sub">Leads generated</div>
        <div class="kpi-stripe" style="background:${expColors[i]};"></div>
      </div>`).join('')}
    </div>
    <div class="grid-2" style="margin-bottom:20px;">
      <div class="chart-card"><div class="chart-card-title">FUNNEL BY EXPERIENCE</div><canvas id="el-grouped" height="160"></canvas></div>
      <div class="chart-card"><div class="chart-card-title">SALES CLOSURE BY EXPERIENCE</div><canvas id="el-closure" height="160"></canvas></div>
    </div>
    <div class="data-table-wrap">
      <div style="display:grid;grid-template-columns:160px 110px 110px 100px 100px 100px;padding:10px 14px;background:var(--ink3);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);border-bottom:1px solid var(--border);">
        <span>Experience Level</span><span>Leads Gen.</span><span>Consumed</span><span>Sales</span><span>L2P %</span><span>Closure %</span>
      </div>
      ${data.map((r,i)=>{const gen=scl(r.gen),cons=scl(r.consumed),sales=scl(r.sales),pipe=Math.round(cons*0.302);
        return `<div style="display:grid;grid-template-columns:160px 110px 110px 100px 100px 100px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;">
          <span style="color:${expColors[i]};font-weight:500;">${r.level}</span>
          <span>${fmt(gen)}</span><span style="color:var(--muted2);">${fmt(cons)}</span>
          <span style="color:var(--accent);font-weight:600;">${fmt(sales)}</span>
          <span style="color:var(--teal);">${pct(pipe,cons)}</span>
          <span style="color:var(--blue);">${pct(sales,cons)}</span>
        </div>`;}).join('')}
    </div>`;

  destroyChart('el-grouped');
  _charts['el-grouped'] = new Chart(document.getElementById('el-grouped'),{
    type:'bar',data:{labels:data.map(r=>r.level.split(' ')[0]),datasets:[
      {label:'Generated',data:data.map(r=>scl(r.gen)),backgroundColor:expColors.map(c=>c+'99'),borderRadius:3},
      {label:'Consumed',data:data.map(r=>scl(r.consumed)),backgroundColor:expColors.map(c=>c+'55'),borderRadius:3},
      {label:'Sales',data:data.map(r=>scl(r.sales)),backgroundColor:expColors,borderRadius:3},
    ]},
    options:{responsive:true,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
  destroyChart('el-closure');
  _charts['el-closure'] = new Chart(document.getElementById('el-closure'),{
    type:'doughnut',data:{labels:data.map(r=>r.level.split(' ')[0]),datasets:[{data:data.map(r=>scl(r.sales)),backgroundColor:expColors,borderWidth:0,hoverOffset:4}]},
    options:{responsive:true,cutout:'60%',plugins:{legend:{position:'right',labels:{font:{size:10}}}}}
  });
}

// ═══════════════════════════════════════════════════════
// VIEW: SOURCE
// ═══════════════════════════════════════════════════════
function renderSource() {
  const el = getPanelEl(); if (!el) return;
  const data = DEMO.sources;
  const totGen=data.reduce((s,r)=>s+scl(r.gen),0);
  const totCons=data.reduce((s,r)=>s+scl(r.consumed),0);
  const totSales=data.reduce((s,r)=>s+scl(r.sales),0);
  const totPipe=Math.round(totCons*0.302);
  const srcColors=['#c8ff57','#4a9eff','#a78bfa','#34d399','#fbbf24'];
  const qualScores=['4.2','3.8','4.6','3.1','2.9'];

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Source <span>Level View</span></div>
      <div class="page-sub">Funnel breakdown by lead source — Apxor, AMA, Calendly, WhatsApp, Email · ${ARPU_CONFIG[currentArpu].label}</div></div>
    </div>
    <div class="summary-strip">
      <div><div class="summary-item-label">Total Leads Generated</div><div class="summary-item-val">${fmt(totGen)}</div></div>
      <div><div class="summary-item-label">Total Leads Consumed</div><div class="summary-item-val">${fmt(totCons)}</div></div>
      <div><div class="summary-item-label">Sales Closed</div><div class="summary-item-val">${fmt(totSales)}</div></div>
      <div><div class="summary-item-label">L2P Rate</div><div class="summary-item-val">${pct(totPipe,totCons)}</div></div>
    </div>
    <div class="grid-2" style="margin-bottom:20px;">
      <div class="chart-card"><div class="chart-card-title">LEADS BY SOURCE</div><canvas id="sl-bar" height="160"></canvas></div>
      <div class="chart-card"><div class="chart-card-title">L2P % BY SOURCE</div><canvas id="sl-l2p" height="160"></canvas></div>
    </div>
    <div class="data-table-wrap">
      <div style="display:grid;grid-template-columns:130px 110px 110px 100px 100px 100px 100px;padding:10px 14px;background:var(--ink3);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);border-bottom:1px solid var(--border);">
        <span>Source</span><span>Leads Gen.</span><span>Consumed</span><span>Sales</span><span>L2P %</span><span>Closure %</span><span>Quality Score</span>
      </div>
      ${data.map((r,i)=>{const gen=scl(r.gen),cons=scl(r.consumed),sales=scl(r.sales),pipe=Math.round(cons*0.302);
        const qs=qualScores[i];
        return `<div style="display:grid;grid-template-columns:130px 110px 110px 100px 100px 100px 100px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;">
          <span style="color:${srcColors[i]};font-weight:600;">${r.name}</span>
          <span>${fmt(gen)}</span><span style="color:var(--muted2);">${fmt(cons)}</span>
          <span style="color:var(--accent);font-weight:600;">${fmt(sales)}</span>
          <span style="color:var(--teal);">${pct(pipe,cons)}</span>
          <span style="color:var(--blue);">${pct(sales,cons)}</span>
          <span><span class="pill ${+qs>=4?'pill-green':+qs>=3.5?'pill-amber':'pill-red'}">${qs}/5</span></span>
        </div>`;}).join('')}
    </div>`;

  destroyChart('sl-bar');
  _charts['sl-bar'] = new Chart(document.getElementById('sl-bar'),{
    type:'bar',data:{labels:data.map(r=>r.name),datasets:[
      {label:'Generated',data:data.map(r=>scl(r.gen)),backgroundColor:srcColors.map(c=>c+'99'),borderRadius:3},
      {label:'Consumed',data:data.map(r=>scl(r.consumed)),backgroundColor:srcColors.map(c=>c+'55'),borderRadius:3},
    ]},
    options:{responsive:true,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
  destroyChart('sl-l2p');
  _charts['sl-l2p'] = new Chart(document.getElementById('sl-l2p'),{
    type:'bar',data:{labels:data.map(r=>r.name),datasets:[{label:'L2P %',data:data.map(r=>(Math.round(scl(r.consumed)*0.302)/scl(r.consumed)*100).toFixed(1)),backgroundColor:srcColors,borderRadius:3}]},
    options:{responsive:true,indexAxis:'y',plugins:{legend:{display:false}},scales:{x:{max:50,ticks:{callback:v=>v+'%'},grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
}

// ═══════════════════════════════════════════════════════
// VIEW: HANDOFF
// ═══════════════════════════════════════════════════════
function renderHandoff() {
  const el = getPanelEl(); if (!el) return;
  const h = DEMO.handoff;

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Handoff <span>Layer</span></div>
      <div class="page-sub">Marketing → Sales handoff: assignment, dialling, connection, show-up, closure · ${ARPU_CONFIG[currentArpu].label}</div></div>
    </div>
    <div class="handoff-grid">
      <div class="handoff-card" style="border-color:rgba(200,255,87,0.2);">
        <div class="handoff-label">Leads Assigned to Sales</div>
        <div class="handoff-value" style="color:var(--accent);">${fmt(scl(h.assigned))}</div>
        <div class="handoff-sub">from marketing pool</div>
      </div>
      <div class="handoff-card" style="border-color:rgba(74,158,255,0.2);">
        <div class="handoff-label">Total Dialled</div>
        <div class="handoff-value" style="color:var(--blue);">${fmt(scl(h.dialled))}</div>
        <div class="handoff-sub">unique leads attempted</div>
      </div>
      <div class="handoff-card" style="border-color:rgba(52,211,153,0.2);">
        <div class="handoff-label">First Contact Success</div>
        <div class="handoff-value" style="color:var(--teal);">${fmt(scl(h.fcs))}</div>
        <div class="handoff-sub">${h.fcsPct}% success rate</div>
      </div>
      <div class="handoff-card" style="border-color:rgba(251,191,36,0.2);">
        <div class="handoff-label">Show-up Rate</div>
        <div class="handoff-value" style="color:var(--amber);">${fmt(scl(h.showup))}</div>
        <div class="handoff-sub">demo / counseling sessions</div>
      </div>
    </div>
    <div class="grid-2" style="margin-bottom:20px;">
      <div>
        <div class="section-header" style="margin-bottom:10px;"><div class="section-title">Connection Rate by Source</div></div>
        <div class="rate-table-wrap">
          <div class="rate-row hdr"><span>Source</span><span>Assigned</span><span>Dialled</span><span>Connected</span><span>Conn %</span><span>Trend</span></div>
          ${h.connBySource.map((r,i)=>`<div class="rate-row">
            <span style="color:${CLRS[i]};font-weight:500;">${r.source}</span>
            <span class="rate-val">${fmt(scl(r.assigned))}</span>
            <span class="rate-val">${fmt(scl(r.dialled))}</span>
            <span class="rate-val" style="color:var(--teal);">${fmt(scl(r.connected))}</span>
            <span class="rate-pct">${r.pct}%<div class="prog-bar-wrap bar"><div class="prog-bar" style="width:${r.pct}%;background:${CLRS[i]};"></div></div></span>
            <span style="color:var(--muted);font-size:10px;">${r.pct>75?'↑ strong':r.pct>60?'→ avg':'↓ low'}</span>
          </div>`).join('')}
        </div>
      </div>
      <div>
        <div class="section-header" style="margin-bottom:10px;"><div class="section-title">Qualification Rate by Source</div></div>
        <div class="rate-table-wrap">
          <div class="rate-row hdr"><span>Source</span><span>Connected</span><span>Qualified</span><span>Qual %</span><span>Pipeline</span><span>Pipe %</span></div>
          ${h.qualBySource.map((r,i)=>`<div class="rate-row">
            <span style="color:${CLRS[i]};font-weight:500;">${r.source}</span>
            <span class="rate-val">${fmt(scl(r.connected))}</span>
            <span class="rate-val" style="color:var(--accent);">${fmt(scl(r.qualified))}</span>
            <span class="rate-pct">${r.qualPct}%<div class="prog-bar-wrap bar"><div class="prog-bar" style="width:${r.qualPct}%;background:${CLRS[i]};"></div></div></span>
            <span class="rate-val">${fmt(scl(r.pipeline))}</span>
            <span style="color:var(--purple);">${r.pipePct}%</span>
          </div>`).join('')}
        </div>
      </div>
    </div>
    <div class="section-header"><div class="section-title">Handoff → Closure Funnel</div></div>
    <div class="grid-2-1">
      <div class="chart-card">
        <div class="chart-card-title">STAGE-BY-STAGE CONVERSION <span>handoff layer</span></div>
        <canvas id="ho-funnel" height="130"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-card-title">CLOSURE BY SOURCE</div>
        <canvas id="ho-closure" height="130"></canvas>
      </div>
    </div>`;

  const hSteps=['Assigned','Dialled','Connected','Qualified','Pipeline','Show-up','Closed'];
  const hVals=[h.assigned,h.dialled,h.fcs,Math.round(h.fcs*0.52),Math.round(h.fcs*0.42),h.showup,h.closure].map(v=>scl(v));
  destroyChart('ho-funnel');
  _charts['ho-funnel']=new Chart(document.getElementById('ho-funnel'),{
    type:'bar',data:{labels:hSteps,datasets:[{label:'Count',data:hVals,backgroundColor:CLRS.concat(['#ff6b6b']),borderRadius:4}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
  destroyChart('ho-closure');
  _charts['ho-closure']=new Chart(document.getElementById('ho-closure'),{
    type:'bar',data:{labels:h.qualBySource.map(r=>r.source),datasets:[{label:'Closed',data:DEMO.sources.map(r=>scl(r.sales)),backgroundColor:CLRS,borderRadius:3}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
  });
}

// ═══════════════════════════════════════════════════════
// VIEW: SALES
// ═══════════════════════════════════════════════════════
function renderSales() {
  const el = getPanelEl(); if (!el) return;
  const cfg = ARPU_CONFIG[currentArpu];
  const hasExtraStages = cfg.salesExtraStages;
  const mul = periodMul();
  const scl2 = v => Math.round(v * mul);

  // Pick correct data set
  const sd = (currentArpu === 'high') ? DEMO.salesHighArpu : DEMO.sales;
  const d = sd.totals;

  // Filter team data
  let teamData = getFilteredTeamData(sd.team);

  // Totals from filtered
  const totConsumed = teamData.reduce((s,r)=>s+scl2(r.consumed),0);
  const totDialled  = teamData.reduce((s,r)=>s+scl2(r.dialled),0);
  const totPipes    = teamData.reduce((s,r)=>s+scl2(r.pipelines),0);
  const totTestRolled = hasExtraStages ? teamData.reduce((s,r)=>s+scl2(r.testRolled||0),0) : 0;
  const totTestCleared = hasExtraStages ? teamData.reduce((s,r)=>s+scl2(r.testCleared||0),0) : 0;
  const totSales    = teamData.reduce((s,r)=>s+scl2(r.sales),0);
  const totTalk     = teamData.reduce((s,r)=>s+scl2(r.talktime),0);

  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const rowColors = ['#c8ff57','#4a9eff','#a78bfa','#34d399','#fbbf24','#ff6b6b','#f472b6'];

  // Extra columns for High ARPU
  const extraHeaders = hasExtraStages
    ? `<span>Test Rolled</span><span>Test Cleared</span>` : '';
  const extraColTemplate = hasExtraStages
    ? `120px 120px` : '';
  const gridCols = hasExtraStages
    ? `160px 110px 110px 110px 120px 120px 110px 110px 90px 90px`
    : `160px 110px 110px 110px 110px 110px 90px 90px`;

  el.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Sales <span>Performance</span></div>
      <div class="page-sub">Pipeline, closures, talk time, dialling activity · ${ARPU_CONFIG[currentArpu].label}
        ${currentTeam !== 'all' ? ' · <span style="color:var(--accent);">'+TEAMS[currentTeam].label+'</span>' : ''}
        ${currentBda !== 'all' ? ' · <span style="color:var(--blue);">'+currentBda+'</span>' : ''}
      </div></div>
      <div class="last-updated">Last updated: today, 09:14 AM</div>
    </div>

    <!-- KPIs -->
    <div class="kpi-row ${hasExtraStages ? 'kpi-row-6' : 'kpi-row-5'}" style="margin-bottom:20px;">
      <div class="kpi-card accent-card">
        <div class="kpi-card-label">Pipelines Created</div>
        <div class="kpi-card-value">${fmt(totPipes)}</div>
        <div class="kpi-card-sub">Qualified → pipeline</div>
        <div class="kpi-stripe" style="background:var(--accent);"></div>
      </div>
      ${hasExtraStages ? `
      <div class="kpi-card" style="border-color:rgba(56,189,248,0.25);background:rgba(56,189,248,0.05);">
        <div class="kpi-card-label">Test Rolled Out</div>
        <div class="kpi-card-value" style="color:#38bdf8;">${fmt(totTestRolled)}</div>
        <div class="kpi-card-sub">Tests sent to pipeline</div>
        <div class="kpi-stripe" style="background:#38bdf8;"></div>
      </div>
      <div class="kpi-card" style="border-color:rgba(251,191,36,0.25);background:rgba(251,191,36,0.05);">
        <div class="kpi-card-label">Test Cleared</div>
        <div class="kpi-card-value" style="color:var(--amber);">${fmt(totTestCleared)}</div>
        <div class="kpi-card-sub">Passed assessment</div>
        <div class="kpi-stripe" style="background:var(--amber);"></div>
      </div>` : ''}
      <div class="kpi-card" style="border-color:rgba(52,211,153,0.25);background:rgba(52,211,153,0.05);">
        <div class="kpi-card-label">Sales Closed</div>
        <div class="kpi-card-value" style="color:var(--teal);">${fmt(totSales)}</div>
        <div class="kpi-card-sub">Converted from pipeline</div>
        <div class="kpi-stripe" style="background:var(--teal);"></div>
      </div>
      <div class="kpi-card" style="border-color:rgba(74,158,255,0.25);background:rgba(74,158,255,0.05);">
        <div class="kpi-card-label">Leads Consumed</div>
        <div class="kpi-card-value" style="color:var(--blue);">${fmt(totConsumed)}</div>
        <div class="kpi-card-sub">Unique leads dialled</div>
        <div class="kpi-stripe" style="background:var(--blue);"></div>
      </div>
      <div class="kpi-card" style="border-color:rgba(251,191,36,0.25);background:rgba(251,191,36,0.05);">
        <div class="kpi-card-label">Talk Time</div>
        <div class="kpi-card-value" style="color:var(--amber);">${fmt(totTalk)} hrs</div>
        <div class="kpi-card-sub">hrs connected this period</div>
        <div class="kpi-stripe" style="background:var(--amber);"></div>
      </div>
    </div>

    <!-- Charts -->
    <div class="grid-2" style="margin-bottom:20px;">
      <div class="chart-card">
        <div class="chart-card-title">PIPELINES VS SALES CLOSED <span>monthly trend</span></div>
        <canvas id="s-trend" height="160"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-card-title">TALK TIME VS LEADS DIALLED <span>daily activity</span></div>
        <canvas id="s-activity" height="160"></canvas>
      </div>
    </div>

    <!-- Team Breakdown -->
    <div class="section-header" style="margin-bottom:12px;">
      <div class="section-title">Team-wise Breakdown
        ${currentTeam !== 'all' ? `<span class="section-badge">${TEAMS[currentTeam].label}</span>` : ''}
        ${currentBda !== 'all' ? `<span class="section-badge" style="color:var(--blue);">${currentBda}</span>` : ''}
      </div>
      <select class="filter-select" id="s-team-metric" onchange="renderSales()">
        <option value="pipelines">Sort: Pipelines</option>
        <option value="sales">Sort: Sales</option>
        <option value="talktime">Sort: Talk Time</option>
        <option value="dialled">Sort: Dialled</option>
      </select>
    </div>

    <div class="data-table-wrap" style="margin-bottom:20px;">
      <div style="display:grid;grid-template-columns:${gridCols};padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
        <span>BDA Name</span><span>Consumed</span><span>Dialled</span><span>Pipelines</span>
        ${hasExtraStages ? '<span>Test Rolled</span><span>Test Cleared</span>' : ''}
        <span>Sales</span><span>Talk Time</span><span>L2P %</span><span>Closure %</span>
      </div>
      <div id="s-team-rows"></div>
      <div id="s-team-totals" style="display:grid;grid-template-columns:${gridCols};padding:11px 14px;background:var(--ink3);border-top:2px solid var(--border2);font-size:12px;font-weight:600;"></div>
    </div>

    <!-- Funnel chart -->
    <div class="grid-2-1">
      <div class="chart-card">
        <div class="chart-card-title">SALES FUNNEL — AGGREGATE <span>consumed → pipeline → closed</span></div>
        <canvas id="s-funnel-chart" height="130"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-card-title">CLOSURE % BY BDA</div>
        <canvas id="s-closure-bda" height="130"></canvas>
      </div>
    </div>`;

  // Trend chart (use mid ARPU monthly for demo)
  const monthlyData = (currentArpu === 'high') ?
    { pipelines:[28,31,35,33,42,46,38,44,50,41,45,54], sales:[9,10,11,10,13,15,12,14,15,13,14,17], talktime:[65,71,79,74,95,105,85,97,109,91,100,121] } :
    DEMO.sales.monthly;

  destroyChart('s-trend');
  _charts['s-trend'] = new Chart(document.getElementById('s-trend'), {
    type: 'bar',
    data: { labels: months, datasets: [
      { label:'Pipelines', data: monthlyData.pipelines, backgroundColor:'rgba(200,255,87,0.55)', borderRadius:3, yAxisID:'y' },
      { label:'Sales Closed', data: monthlyData.sales, backgroundColor:'rgba(52,211,153,0.8)', borderRadius:3, yAxisID:'y' },
      ...(hasExtraStages ? [{ label:'Test Cleared', data: monthlyData.pipelines.map(v=>Math.round(v*0.7)), type:'line', borderColor:'#fbbf24', tension:0.4, pointRadius:3, yAxisID:'y' }] : []),
      { label:'Talk Time (hrs)', data: monthlyData.talktime, type:'line', borderColor:'#fbbf24', tension:0.4, pointRadius:3, yAxisID:'y2' },
    ]},
    options:{ responsive:true, plugins:{ legend:{ position:'top' } }, scales:{ x:{ grid:{color:'rgba(255,255,255,0.04)'} }, y:{ grid:{color:'rgba(255,255,255,0.04)'}, position:'left' }, y2:{ grid:{display:false}, position:'right', ticks:{callback:v=>v+'h'} } } }
  });

  destroyChart('s-activity');
  _charts['s-activity'] = new Chart(document.getElementById('s-activity'), {
    type: 'line',
    data: { labels: months, datasets: [
      { label:'Leads Dialled', data: monthlyData.talktime.map(v=>Math.round(v*2.24)), borderColor:'#a78bfa', backgroundColor:'rgba(167,139,250,0.07)', tension:0.4, fill:true, pointRadius:3 },
      { label:'Leads Consumed', data: monthlyData.talktime.map(v=>Math.round(v*1.46)), borderColor:'#4a9eff', backgroundColor:'rgba(74,158,255,0.05)', tension:0.4, fill:true, pointRadius:3 },
    ]},
    options:{ responsive:true, plugins:{ legend:{ position:'top' } }, scales:{ x:{ grid:{color:'rgba(255,255,255,0.04)'} }, y:{ grid:{color:'rgba(255,255,255,0.04)'} } } }
  });

  // Team table
  const metricKey = document.getElementById('s-team-metric')?.value || 'pipelines';
  const sorted = [...teamData].sort((a,b) => b[metricKey] - a[metricKey]);

  document.getElementById('s-team-rows').innerHTML = sorted.map((r,i) => {
    const cons=scl2(r.consumed), dial=scl2(r.dialled), pipes=scl2(r.pipelines),
          tr=scl2(r.testRolled||0), tc=scl2(r.testCleared||0),
          sales2=scl2(r.sales), talk=scl2(r.talktime);
    const l2p = cons ? (pipes/cons*100).toFixed(1) : '—';
    const closure = cons ? (sales2/cons*100).toFixed(1) : '—';
    const teamLabel = Object.entries(TEAMS).find(([k,v])=>k===r.team)?.[1]?.label||'';
    return `<div style="display:grid;grid-template-columns:${gridCols};padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
      <span style="color:${rowColors[i%rowColors.length]};font-weight:600;">${r.name}<br><span style="color:var(--muted);font-size:9px;font-weight:400;">${teamLabel}</span></span>
      <span>${fmt(cons)}</span>
      <span style="color:var(--muted2);">${fmt(dial)}</span>
      <span style="color:var(--accent);font-weight:600;">${fmt(pipes)}</span>
      ${hasExtraStages ? `<span style="color:#38bdf8;">${fmt(tr)}</span><span style="color:var(--amber);">${fmt(tc)}</span>` : ''}
      <span style="color:var(--teal);font-weight:600;">${fmt(sales2)}</span>
      <span style="color:var(--amber);">${fmt(talk)} hrs</span>
      <span style="color:var(--blue);">${l2p}%</span>
      <span style="color:var(--purple);">${closure}%</span>
    </div>`;
  }).join('');

  document.getElementById('s-team-totals').innerHTML = `
    <span style="color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:1px;">TOTAL</span>
    <span>${fmt(totConsumed)}</span>
    <span style="color:var(--muted2);">${fmt(totDialled)}</span>
    <span style="color:var(--accent);">${fmt(totPipes)}</span>
    ${hasExtraStages ? `<span style="color:#38bdf8;">${fmt(totTestRolled)}</span><span style="color:var(--amber);">${fmt(totTestCleared)}</span>` : ''}
    <span style="color:var(--teal);">${fmt(totSales)}</span>
    <span style="color:var(--amber);">${fmt(totTalk)} hrs</span>
    <span style="color:var(--blue);">${totPipes&&totConsumed?(totPipes/totConsumed*100).toFixed(1):'—'}%</span>
    <span style="color:var(--purple);">${totSales&&totConsumed?(totSales/totConsumed*100).toFixed(1):'—'}%</span>`;

  // Sales funnel stages
  let funnelLabels, funnelVals;
  if (hasExtraStages) {
    funnelLabels=['Consumed','Connected','Qualified','Pipeline','Test Rolled','Test Cleared','Demo','Closed'];
    funnelVals=[scl2(sd.totals.consumed||920),scl2(680),scl2(380),scl2(sd.totals.pipelines||310),scl2(sd.totals.testRolled||220),scl2(sd.totals.testCleared||148),scl2(130),scl2(sd.totals.sales||98)];
  } else {
    funnelLabels=['Consumed','Connected','Qualified','Pipeline','Demo','Closed'];
    funnelVals=[scl2(2690),scl2(1920),scl2(1010),scl2(812),scl2(560),scl2(247)];
  }

  destroyChart('s-funnel-chart');
  _charts['s-funnel-chart'] = new Chart(document.getElementById('s-funnel-chart'), {
    type:'bar', data:{ labels:funnelLabels, datasets:[{label:'Count',data:funnelVals,backgroundColor:['#c8ff5799','#4a9eff99','#a78bfa99','#c8ff57','#38bdf899','#fbbf2499','#34d39999','#34d399'],borderRadius:4}] },
    options:{ responsive:true, plugins:{legend:{display:false}}, scales:{ x:{grid:{color:'rgba(255,255,255,0.04)'}}, y:{grid:{color:'rgba(255,255,255,0.04)'}} } }
  });

  destroyChart('s-closure-bda');
  _charts['s-closure-bda'] = new Chart(document.getElementById('s-closure-bda'), {
    type:'bar', data:{ labels: sorted.map(r=>r.name.split(' ')[0]), datasets:[{label:'Closure %',data:sorted.map(r=>(r.sales/r.consumed*100).toFixed(1)),backgroundColor:rowColors,borderRadius:3}] },
    options:{ responsive:true, indexAxis:'y', plugins:{legend:{display:false}}, scales:{ x:{max:15,ticks:{callback:v=>v+'%'},grid:{color:'rgba(255,255,255,0.04)'}}, y:{grid:{color:'rgba(255,255,255,0.04)'}} } }
  });
}

// ═══════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════
function handlePeriodChange() {
  const val = document.getElementById('periodFilter').value;
  document.getElementById('custom-date-wrap').style.display = val === 'custom' ? 'flex' : 'none';
  if (val !== 'custom') refreshAll();
}

function refreshAll() { renderCurrentView(); }
function exportData() { alert('Connect to Scaler CRM API to export live data.\nClick the API status indicator in the top-right to configure.'); }

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
function init() {
  // Set Mid ARPU as default
  const cfg = ARPU_CONFIG['mid'];
  const ps = document.getElementById('programFilter');
  ps.innerHTML = cfg.programs.map((p,i) => `<option value="${cfg.programKeys[i]}">${p}</option>`).join('');
  buildContextBar();
  buildSubNav();
  buildCanvas();
  renderCurrentView();
}


// ═══════════════════════════════════════════════════════
// TOP-LEVEL SECTION SWITCH
// ═══════════════════════════════════════════════════════
let currentSection = 'marketing';

function switchSection(section, el) {
  currentSection = section;
  // Update tab styles
  document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');

  // Show/hide section wrappers
  ['marketing','crm','audit','completion'].forEach(s => {
    const el2 = document.getElementById('section-' + s);
    if (el2) el2.style.display = s === section ? '' : 'none';
  });

  // Render the newly visible section
  if (section === 'crm') renderCrm('overview');
  if (section === 'audit') renderAudit('calls');
  if (section === 'completion') renderCompletion('overview');
}

// ═══════════════════════════════════════════════════════
// CRM SECTION
// ═══════════════════════════════════════════════════════
let currentCrmTab = 'overview';
function switchCrmTab(tab, el) {
  currentCrmTab = tab;
  document.querySelectorAll('#section-crm .sub-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderCrm(tab);
}

