function renderCrm(tab) {
  const canvas = document.getElementById('crm-canvas');
  if (!canvas) return;
  if (tab === 'overview') {
    const d = CRM_DEMO.overview;
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">CRM <span>Overview</span></div>
        <div class="page-sub">Lead lifecycle management — all ARPU segments combined</div></div>
        <div class="last-updated">Last updated: today, 09:14 AM</div>
      </div>
      <div class="crm-grid">
        <div class="crm-card" style="border-color:rgba(200,255,87,0.25);">
          <div class="crm-label">Total Leads</div>
          <div class="crm-value" style="color:var(--accent);">${fmt(d.totalLeads)}</div>
          <div class="crm-sub">in system this period</div>
          <div class="kpi-stripe" style="background:var(--accent);"></div>
        </div>
        <div class="crm-card" style="border-color:rgba(74,158,255,0.25);">
          <div class="crm-label">Open Pipelines</div>
          <div class="crm-value" style="color:var(--blue);">${d.openPipelines}</div>
          <div class="crm-sub">active deals in progress</div>
          <div class="kpi-stripe" style="background:var(--blue);"></div>
        </div>
        <div class="crm-card" style="border-color:rgba(251,191,36,0.25);">
          <div class="crm-label">Scheduled Follow-ups</div>
          <div class="crm-value" style="color:var(--amber);">${d.scheduledFollowups}</div>
          <div class="crm-sub">due in next 48 hrs</div>
          <div class="kpi-stripe" style="background:var(--amber);"></div>
        </div>
        <div class="crm-card" style="border-color:rgba(52,211,153,0.25);">
          <div class="crm-label">Closed Won</div>
          <div class="crm-value" style="color:var(--teal);">${d.closedWon}</div>
          <div class="crm-sub">vs ${d.closedLost} lost · avg ${d.avgDealAge}d deal age</div>
          <div class="kpi-stripe" style="background:var(--teal);"></div>
        </div>
      </div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="chart-card">
          <div class="chart-card-title">PIPELINE STAGE DISTRIBUTION</div>
          <canvas id="crm-pipeline-chart" height="180"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-card-title">WIN / LOSS TREND <span>monthly</span></div>
          <canvas id="crm-winloss-chart" height="180"></canvas>
        </div>
      </div>
      <div class="section-header" style="margin-bottom:12px;"><div class="section-title">Stage Breakdown</div></div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:160px 100px 120px 100px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Stage</span><span>Count</span><span>Est. Value</span><span>WoW Change</span>
        </div>
        ${CRM_DEMO.pipeline.map(r => `
          <div style="display:grid;grid-template-columns:160px 100px 120px 100px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;">
            <span style="display:flex;align-items:center;gap:8px;">
              <span style="width:8px;height:8px;border-radius:50%;background:${r.color};display:inline-block;"></span>
              ${r.stage}
            </span>
            <span style="font-weight:600;">${r.count}</span>
            <span style="color:var(--accent);">${r.value}</span>
            <span class="${r.change.startsWith('+') ? 'pill pill-green' : 'pill pill-red'}">${r.change}</span>
          </div>`).join('')}
      </div>`;

    destroyChart('crm-pipeline-chart');
    _charts['crm-pipeline-chart'] = new Chart(document.getElementById('crm-pipeline-chart'), {
      type: 'bar',
      data: { labels: CRM_DEMO.pipeline.map(r=>r.stage), datasets:[{ label:'Count', data: CRM_DEMO.pipeline.map(r=>r.count), backgroundColor: CRM_DEMO.pipeline.map(r=>r.color+'cc'), borderRadius:4 }] },
      options: { responsive:true, plugins:{legend:{display:false}}, scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}} }
    });
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    destroyChart('crm-winloss-chart');
    _charts['crm-winloss-chart'] = new Chart(document.getElementById('crm-winloss-chart'), {
      type: 'line',
      data: { labels: months, datasets:[
        { label:'Won', data:[18,20,22,21,27,30,24,28,31,26,29,35], borderColor:'#34d399', backgroundColor:'rgba(52,211,153,0.07)', tension:0.4, fill:true, pointRadius:3 },
        { label:'Lost', data:[14,16,18,17,22,25,20,22,26,21,24,28], borderColor:'#ff6b6b', backgroundColor:'rgba(255,107,107,0.05)', tension:0.4, fill:true, pointRadius:3 },
      ]},
      options:{ responsive:true, plugins:{legend:{position:'top'}}, scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}} }
    });

  } else if (tab === 'leads') {
    const statusColor = { 'New':'#4a9eff','Contacted':'#fbbf24','Pipeline':'#c8ff57','Follow-up':'#a78bfa','Lost':'#ff6b6b','Closed Won':'#34d399' };
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Lead <span>Register</span></div>
        <div class="page-sub">All leads in the system with current status and assignment</div></div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:160px 140px 90px 110px 110px 120px 130px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Lead Name</span><span>Phone</span><span>Source</span><span>Program</span><span>Status</span><span>Assigned To</span><span>Created</span>
        </div>
        ${CRM_DEMO.leads.map(r => `
          <div style="display:grid;grid-template-columns:160px 140px 90px 110px 110px 120px 130px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="font-weight:600;">${r.name}</span>
            <span style="color:var(--muted2);font-size:11px;">${r.phone}</span>
            <span><span class="pill pill-blue">${r.source}</span></span>
            <span style="color:var(--muted2);font-size:11px;">${r.program}</span>
            <span><span style="display:inline-block;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:500;background:${statusColor[r.status]}22;color:${statusColor[r.status]};">${r.status}</span></span>
            <span style="font-size:11px;">${r.assignedTo}</span>
            <span style="color:var(--muted);font-size:10px;">${r.createdAt}</span>
          </div>`).join('')}
      </div>`;

  } else if (tab === 'pipeline') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Pipeline <span>View</span></div>
        <div class="page-sub">Active deals by stage with estimated values</div></div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;">
        ${CRM_DEMO.pipeline.filter(r=>!['Closed Won','Closed Lost'].includes(r.stage)).map(r=>`
          <div class="crm-card" style="border-color:${r.color}33;">
            <div class="crm-label">${r.stage}</div>
            <div class="crm-value" style="color:${r.color};">${r.count}</div>
            <div style="display:flex;justify-content:space-between;margin-top:6px;">
              <span style="color:var(--muted);font-size:10px;">${r.value}</span>
              <span class="${r.change.startsWith('+') ? 'pill pill-green' : 'pill pill-red'}" style="font-size:9px;">${r.change}</span>
            </div>
            <div class="kpi-stripe" style="background:${r.color};"></div>
          </div>`).join('')}
      </div>
      <div class="chart-card">
        <div class="chart-card-title">PIPELINE FUNNEL</div>
        <canvas id="crm-pipe-funnel" height="100"></canvas>
      </div>`;
    destroyChart('crm-pipe-funnel');
    const pd = CRM_DEMO.pipeline.filter(r=>!['Closed Won','Closed Lost'].includes(r.stage));
    _charts['crm-pipe-funnel'] = new Chart(document.getElementById('crm-pipe-funnel'), {
      type:'bar', data:{ labels:pd.map(r=>r.stage), datasets:[{label:'Deals',data:pd.map(r=>r.count),backgroundColor:pd.map(r=>r.color+'bb'),borderRadius:4}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });

  } else if (tab === 'followups') {
    const priColor = { High:'#ff6b6b', Medium:'#fbbf24', Low:'#4a9eff' };
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Follow-up <span>Queue</span></div>
        <div class="page-sub">Scheduled callbacks and pending actions — sorted by urgency</div></div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:160px 130px 140px 80px 1fr;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Lead</span><span>BDA</span><span>Due</span><span>Priority</span><span>Note</span>
        </div>
        ${CRM_DEMO.followups.map(r=>`
          <div style="display:grid;grid-template-columns:160px 130px 140px 80px 1fr;padding:11px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="font-weight:600;">${r.lead}</span>
            <span style="color:var(--muted2);">${r.bda}</span>
            <span style="color:var(--amber);font-size:11px;">${r.dueIn}</span>
            <span><span style="display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:${priColor[r.priority]}22;color:${priColor[r.priority]};">${r.priority}</span></span>
            <span style="color:var(--muted);font-size:11px;">${r.note}</span>
          </div>`).join('')}
      </div>`;

  } else if (tab === 'lost') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Lost / <span>Dropped</span></div>
        <div class="page-sub">Deals marked lost — reasons and recoverability</div></div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:160px 180px 130px 80px 80px 100px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Lead</span><span>Reason</span><span>BDA</span><span>Lost On</span><span>Value</span><span>Recoverable</span>
        </div>
        ${CRM_DEMO.lost.map(r=>`
          <div style="display:grid;grid-template-columns:160px 180px 130px 80px 80px 100px;padding:11px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="font-weight:600;">${r.lead}</span>
            <span style="color:var(--coral);">${r.reason}</span>
            <span style="color:var(--muted2);">${r.bda}</span>
            <span style="color:var(--muted);font-size:11px;">${r.lostOn}</span>
            <span style="color:var(--accent);">${r.value}</span>
            <span><span class="pill ${r.recoverable?'pill-green':'pill-red'}">${r.recoverable?'Yes':'No'}</span></span>
          </div>`).join('')}
      </div>`;
  }
}

