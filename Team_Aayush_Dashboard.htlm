  calls: [
    { id:'CALL-2841', bda:'Aryan Mehta',  lead:'Rahul Sharma',   date:'Today, 09:02', duration:'18m 24s', score:87, outcome:'Pipeline',    flags:0 },
    { id:'CALL-2840', bda:'Priya Singh',  lead:'Anjali Verma',   date:'Today, 08:45', duration:'22m 10s', score:74, outcome:'Follow-up',   flags:1 },
