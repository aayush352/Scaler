function renderAudit(tab) {
  const canvas = document.getElementById('audit-canvas');
  if (!canvas) return;

  if (tab === 'calls') {
    const scoreColor = s => s>=85?'var(--teal)':s>=70?'var(--amber)':'var(--coral)';
    const scoreBg = s => s>=85?'rgba(52,211,153,0.15)':s>=70?'rgba(251,191,36,0.15)':'rgba(255,107,107,0.15)';
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Call <span>Audits</span></div>
        <div class="page-sub">Recent call recordings scored on quality, compliance and conversion</div></div>
        <div class="last-updated">Last updated: today, 09:14 AM</div>
      </div>
      <div class="kpi-row kpi-row-4" style="margin-bottom:20px;">
        <div class="kpi-card" style="border-color:rgba(200,255,87,0.2);">
          <div class="kpi-card-label">Calls Audited</div>
          <div class="kpi-card-value" style="color:var(--accent);">847</div>
          <div class="kpi-card-sub">this month</div>
          <div class="kpi-stripe" style="background:var(--accent);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(52,211,153,0.2);">
          <div class="kpi-card-label">Avg Quality Score</div>
          <div class="kpi-card-value" style="color:var(--teal);">76.4</div>
          <div class="kpi-card-sub">out of 100</div>
          <div class="kpi-stripe" style="background:var(--teal);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(255,107,107,0.2);">
          <div class="kpi-card-label">Flagged Calls</div>
          <div class="kpi-card-value" style="color:var(--coral);">34</div>
          <div class="kpi-card-sub">require review</div>
          <div class="kpi-stripe" style="background:var(--coral);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(251,191,36,0.2);">
          <div class="kpi-card-label">Avg Call Duration</div>
          <div class="kpi-card-value" style="color:var(--amber);">18.7m</div>
          <div class="kpi-card-sub">minutes per call</div>
          <div class="kpi-stripe" style="background:var(--amber);"></div>
        </div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:100px 130px 140px 120px 110px 80px 110px 70px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Call ID</span><span>BDA</span><span>Lead</span><span>Date</span><span>Duration</span><span>Score</span><span>Outcome</span><span>Flags</span>
        </div>
        ${AUDIT_DEMO.calls.map(r=>`
          <div style="display:grid;grid-template-columns:100px 130px 140px 120px 110px 80px 110px 70px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="color:var(--muted2);font-size:11px;">${r.id}</span>
            <span style="font-weight:500;">${r.bda}</span>
            <span style="color:var(--muted2);">${r.lead}</span>
            <span style="color:var(--muted);font-size:11px;">${r.date}</span>
            <span style="color:var(--muted2);">${r.duration}</span>
            <span><span class="audit-score" style="background:${scoreBg(r.score)};color:${scoreColor(r.score)};">${r.score}</span></span>
            <span style="font-size:11px;">${r.outcome}</span>
            <span>${r.flags > 0 ? '<span class="pill pill-red">⚑ '+r.flags+'</span>' : '<span style="color:var(--muted);font-size:11px;">—</span>'}</span>
          </div>`).join('')}
      </div>`;

  } else if (tab === 'bda') {
    const scoreColor = s => s>=85?'var(--teal)':s>=70?'var(--amber)':'var(--coral)';
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">BDA <span>Scores</span></div>
        <div class="page-sub">Aggregated quality scores per BDA with strengths and improvement areas</div></div>
      </div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="chart-card">
          <div class="chart-card-title">AVG QUALITY SCORE BY BDA</div>
          <canvas id="audit-bda-bar" height="180"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-card-title">FLAGGED CALLS BY BDA</div>
          <canvas id="audit-flag-bar" height="180"></canvas>
        </div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:150px 80px 90px 80px 160px 160px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>BDA Name</span><span>Calls</span><span>Avg Score</span><span>Flagged</span><span>Top Skill</span><span>Needs Work</span>
        </div>
        ${AUDIT_DEMO.bdaScores.map(r=>`
          <div style="display:grid;grid-template-columns:150px 80px 90px 80px 160px 160px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="font-weight:600;">${r.name}</span>
            <span style="color:var(--muted2);">${r.calls}</span>
            <span><span class="audit-score" style="background:${scoreColor(r.avgScore)}22;color:${scoreColor(r.avgScore)};">${r.avgScore}</span></span>
            <span>${r.flagged>8?'<span class="pill pill-red">'+r.flagged+'</span>':r.flagged>4?'<span class="pill pill-amber">'+r.flagged+'</span>':'<span class="pill pill-green">'+r.flagged+'</span>'}</span>
            <span style="color:var(--teal);font-size:11px;">✓ ${r.top}</span>
            <span style="color:var(--coral);font-size:11px;">↑ ${r.weak}</span>
          </div>`).join('')}
      </div>`;

    const names = AUDIT_DEMO.bdaScores.map(r=>r.name.split(' ')[0]);
    destroyChart('audit-bda-bar');
    _charts['audit-bda-bar'] = new Chart(document.getElementById('audit-bda-bar'), {
      type:'bar', data:{labels:names, datasets:[{label:'Avg Score',data:AUDIT_DEMO.bdaScores.map(r=>r.avgScore),backgroundColor:AUDIT_DEMO.bdaScores.map(r=>r.avgScore>=85?'#34d39999':r.avgScore>=70?'#fbbf2499':'#ff6b6b99'),borderRadius:3}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{min:0,max:100,grid:{color:'rgba(255,255,255,0.04)'}},x:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });
    destroyChart('audit-flag-bar');
    _charts['audit-flag-bar'] = new Chart(document.getElementById('audit-flag-bar'), {
      type:'bar', data:{labels:names, datasets:[{label:'Flagged',data:AUDIT_DEMO.bdaScores.map(r=>r.flagged),backgroundColor:'rgba(255,107,107,0.6)',borderRadius:3}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });

  } else if (tab === 'flags') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Flagged <span>Calls</span></div>
        <div class="page-sub">Calls flagged for compliance issues, script deviations, or quality drops</div></div>
      </div>
      <div class="summary-strip">
        <div><div class="summary-item-label">Total Flagged</div><div class="summary-item-val" style="color:var(--coral);">34</div></div>
        <div><div class="summary-item-label">Critical Flags</div><div class="summary-item-val" style="color:var(--coral);">8</div></div>
        <div><div class="summary-item-label">Reviewed</div><div class="summary-item-val">19</div></div>
        <div><div class="summary-item-label">Pending Review</div><div class="summary-item-val" style="color:var(--amber);">15</div></div>
      </div>
      ${AUDIT_DEMO.calls.filter(r=>r.flags>0).map(r=>`
        <div class="chart-card" style="margin-bottom:12px;border-color:rgba(255,107,107,0.2);">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
            <div>
              <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:13px;">${r.bda} <span style="color:var(--muted);font-weight:400;">→</span> ${r.lead}</div>
              <div style="font-size:10px;color:var(--muted);margin-top:3px;">${r.id} · ${r.date} · ${r.duration}</div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <span class="pill pill-red">⚑ ${r.flags} flag${r.flags>1?'s':''}</span>
              <span class="audit-score" style="background:rgba(255,107,107,0.15);color:var(--coral);">${r.score}</span>
              <button class="filter-btn" style="font-size:10px;">Review →</button>
            </div>
          </div>
        </div>`).join('')}`;

  } else if (tab === 'trends') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Score <span>Trends</span></div>
        <div class="page-sub">Quality score trajectory over time — team and individual</div></div>
      </div>
      <div class="grid-2">
        <div class="chart-card">
          <div class="chart-card-title">TEAM AVG SCORE — MONTHLY TREND</div>
          <canvas id="audit-trend-team" height="180"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-card-title">FLAGGED CALLS — MONTHLY TREND</div>
          <canvas id="audit-trend-flags" height="180"></canvas>
        </div>
      </div>`;
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    destroyChart('audit-trend-team');
    _charts['audit-trend-team'] = new Chart(document.getElementById('audit-trend-team'), {
      type:'line', data:{labels:months, datasets:[
        {label:'Team Avg',data:[68,70,72,71,74,76,75,77,79,78,80,76],borderColor:'#c8ff57',backgroundColor:'rgba(200,255,87,0.06)',tension:0.4,fill:true,pointRadius:3},
        {label:'Top Performer',data:[80,82,84,83,86,88,87,89,91,90,92,88],borderColor:'#34d399',tension:0.4,pointRadius:3},
      ]},
      options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{min:50,max:100,grid:{color:'rgba(255,255,255,0.04)'}},x:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });
    destroyChart('audit-trend-flags');
    _charts['audit-trend-flags'] = new Chart(document.getElementById('audit-trend-flags'), {
      type:'bar', data:{labels:months, datasets:[{label:'Flagged',data:[42,38,35,37,32,28,31,27,24,26,22,34],backgroundColor:'rgba(255,107,107,0.6)',borderRadius:3}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });
  }
}

// ═══════════════════════════════════════════════════════
// COMPLETION SECTION
// ═══════════════════════════════════════════════════════
let currentCompTab = 'overview';
function switchCompTab(tab, el) {
  currentCompTab = tab;
  document.querySelectorAll('#section-completion .sub-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderCompletion(tab);
}

const COMP_DEMO = {
  tracks: [
    { name:'MS in AI',        enrolled:284, completed:198, inProgress:62,  dropped:24, pct:70, color:'#c8ff57' },
    { name:'Neovarsity',      enrolled:210, completed:140, inProgress:55,  dropped:15, pct:67, color:'#4a9eff' },
    { name:'DSML',            enrolled:176, completed:118, inProgress:42,  dropped:16, pct:67, color:'#a78bfa' },
    { name:'AIML',            enrolled:152, completed:98,  inProgress:38,  dropped:16, pct:64, color:'#fbbf24' },
    { name:'DevOps',          enrolled:128, completed:80,  inProgress:34,  dropped:14, pct:63, color:'#34d399' },
    { name:'IITR',            enrolled:320, completed:200, inProgress:88,  dropped:32, pct:63, color:'#f472b6' },
    { name:'IIMT',            enrolled:280, completed:168, inProgress:78,  dropped:34, pct:60, color:'#ff6b6b' },
    { name:'Oxford',          enrolled:96,  completed:58,  inProgress:26,  dropped:12, pct:60, color:'#38bdf8' },
    { name:'Academy',         enrolled:64,  completed:36,  inProgress:20,  dropped:8,  pct:56, color:'#818cf8' },
  ],
  cohorts: [
    { cohort:'Cohort 24A (Jan)',  enrolled:180, completed:142, pct:79, status:'Completed' },
    { cohort:'Cohort 24B (Apr)',  enrolled:195, completed:138, pct:71, status:'Completed' },
    { cohort:'Cohort 24C (Jul)',  enrolled:210, completed:124, pct:59, status:'In Progress' },
    { cohort:'Cohort 24D (Oct)',  enrolled:224, completed:88,  pct:39, status:'In Progress' },
    { cohort:'Cohort 25A (Jan)',  enrolled:241, completed:41,  pct:17, status:'Early Stage' },
  ],
  atRisk: [
    { name:'Priya Kapoor',  program:'MS in AI',   progress:'12%', lastActive:'8d ago',  risk:'High',   mentor:'Assign' },
    { name:'Rohit Sharma',  program:'DSML',        progress:'28%', lastActive:'5d ago',  risk:'High',   mentor:'Aryan' },
    { name:'Kavya Nair',    program:'IITR',        progress:'41%', lastActive:'3d ago',  risk:'Medium', mentor:'Priya' },
    { name:'Saurav Ghosh',  program:'Neovarsity',  progress:'35%', lastActive:'4d ago',  risk:'Medium', mentor:'Assign' },
    { name:'Trisha Menon',  program:'AIML',        progress:'55%', lastActive:'2d ago',  risk:'Low',    mentor:'Deepa' },
    { name:'Varun Bhat',    program:'IIMT',        progress:'48%', lastActive:'3d ago',  risk:'Low',    mentor:'Rohan' },
  ]
};

function renderCompletion(tab) {
  const canvas = document.getElementById('comp-canvas');
  if (!canvas) return;

  if (tab === 'overview') {
    const total = COMP_DEMO.tracks.reduce((s,r)=>s+r.enrolled,0);
    const done  = COMP_DEMO.tracks.reduce((s,r)=>s+r.completed,0);
    const prog  = COMP_DEMO.tracks.reduce((s,r)=>s+r.inProgress,0);
    const drop  = COMP_DEMO.tracks.reduce((s,r)=>s+r.dropped,0);
    const overallPct = Math.round(done/total*100);

    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Completion <span>Overview</span></div>
        <div class="page-sub">Course completion rates across all programs and cohorts</div></div>
      </div>
      <div class="kpi-row kpi-row-4" style="margin-bottom:20px;">
        <div class="kpi-card accent-card">
          <div class="kpi-card-label">Overall Completion Rate</div>
          <div class="kpi-card-value">${overallPct}%</div>
          <div class="kpi-card-sub">${fmt(done)} of ${fmt(total)} enrolled</div>
          <div class="kpi-stripe" style="background:var(--accent);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(74,158,255,0.25);">
          <div class="kpi-card-label">In Progress</div>
          <div class="kpi-card-value" style="color:var(--blue);">${fmt(prog)}</div>
          <div class="kpi-card-sub">active learners</div>
          <div class="kpi-stripe" style="background:var(--blue);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(255,107,107,0.25);">
          <div class="kpi-card-label">Dropped Out</div>
          <div class="kpi-card-value" style="color:var(--coral);">${fmt(drop)}</div>
          <div class="kpi-card-sub">${Math.round(drop/total*100)}% dropout rate</div>
          <div class="kpi-stripe" style="background:var(--coral);"></div>
        </div>
        <div class="kpi-card" style="border-color:rgba(251,191,36,0.25);">
          <div class="kpi-card-label">At Risk Learners</div>
          <div class="kpi-card-value" style="color:var(--amber);">${COMP_DEMO.atRisk.length}</div>
          <div class="kpi-card-sub">need intervention</div>
          <div class="kpi-stripe" style="background:var(--amber);"></div>
        </div>
      </div>
      <div class="section-header" style="margin-bottom:12px;"><div class="section-title">Completion by Program</div></div>
      ${COMP_DEMO.tracks.map(r=>`
        <div class="comp-track">
          <div class="comp-track-header">
            <div>
              <div class="comp-track-name">${r.name}</div>
              <div style="font-size:10px;color:var(--muted);margin-top:3px;">${r.enrolled} enrolled · ${r.completed} completed · ${r.dropped} dropped</div>
            </div>
            <div style="display:flex;align-items:center;gap:14px;">
              <div style="text-align:right;">
                <div class="comp-track-pct" style="color:${r.color};">${r.pct}%</div>
                <div style="font-size:9px;color:var(--muted);">completion</div>
              </div>
            </div>
          </div>
          <div class="comp-bar-outer">
            <div class="comp-bar-inner" style="width:${r.pct}%;background:${r.color};"></div>
          </div>
        </div>`).join('')}`;

  } else if (tab === 'cohort') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Cohort <span>Wise</span></div>
        <div class="page-sub">Completion rates broken down by enrollment cohort</div></div>
      </div>
      <div class="chart-card" style="margin-bottom:20px;">
        <div class="chart-card-title">COMPLETION % BY COHORT</div>
        <canvas id="comp-cohort-bar" height="120"></canvas>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:200px 100px 110px 80px 120px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Cohort</span><span>Enrolled</span><span>Completed</span><span>Pct</span><span>Status</span>
        </div>
        ${COMP_DEMO.cohorts.map((r,i)=>`
          <div style="display:grid;grid-template-columns:200px 100px 110px 80px 120px;padding:10px 14px;border-bottom:1px solid var(--border);align-items:center;">
            <span style="font-weight:500;">${r.cohort}</span>
            <span>${r.enrolled}</span>
            <span style="color:var(--teal);">${r.completed}</span>
            <span>
              <div style="display:flex;align-items:center;gap:6px;">
                <div class="prog-bar-wrap" style="width:60px;"><div class="prog-bar" style="width:${r.pct}%;background:${CLRS[i]};"></div></div>
                <span style="color:${CLRS[i]};">${r.pct}%</span>
              </div>
            </span>
            <span><span class="pill ${r.status==='Completed'?'pill-green':r.status==='In Progress'?'pill-blue':'pill-amber'}">${r.status}</span></span>
          </div>`).join('')}
      </div>`;
    destroyChart('comp-cohort-bar');
    _charts['comp-cohort-bar'] = new Chart(document.getElementById('comp-cohort-bar'), {
      type:'bar', data:{labels:COMP_DEMO.cohorts.map(r=>r.cohort.split('(')[0].trim()),datasets:[
        {label:'Enrolled',data:COMP_DEMO.cohorts.map(r=>r.enrolled),backgroundColor:'rgba(200,255,87,0.3)',borderRadius:3},
        {label:'Completed',data:COMP_DEMO.cohorts.map(r=>r.completed),backgroundColor:'rgba(52,211,153,0.7)',borderRadius:3},
      ]},
      options:{responsive:true,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });

  } else if (tab === 'program') {
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">Program <span>Wise</span></div>
        <div class="page-sub">Detailed completion metrics per program</div></div>
      </div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="chart-card">
          <div class="chart-card-title">COMPLETION % BY PROGRAM</div>
          <canvas id="comp-prog-bar" height="220"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-card-title">DROPOUT DISTRIBUTION</div>
          <canvas id="comp-drop-donut" height="220"></canvas>
        </div>
      </div>`;
    destroyChart('comp-prog-bar');
    _charts['comp-prog-bar'] = new Chart(document.getElementById('comp-prog-bar'), {
      type:'bar', data:{labels:COMP_DEMO.tracks.map(r=>r.name),datasets:[{label:'Completion %',data:COMP_DEMO.tracks.map(r=>r.pct),backgroundColor:COMP_DEMO.tracks.map(r=>r.color+'cc'),borderRadius:3}]},
      options:{responsive:true,indexAxis:'y',plugins:{legend:{display:false}},scales:{x:{max:100,ticks:{callback:v=>v+'%'},grid:{color:'rgba(255,255,255,0.04)'}},y:{grid:{color:'rgba(255,255,255,0.04)'}}}}
    });
    destroyChart('comp-drop-donut');
    _charts['comp-drop-donut'] = new Chart(document.getElementById('comp-drop-donut'), {
      type:'doughnut', data:{labels:COMP_DEMO.tracks.map(r=>r.name),datasets:[{data:COMP_DEMO.tracks.map(r=>r.dropped),backgroundColor:COMP_DEMO.tracks.map(r=>r.color),borderWidth:0,hoverOffset:4}]},
      options:{responsive:true,cutout:'55%',plugins:{legend:{position:'right',labels:{font:{size:10},boxWidth:10}}}}
    });

  } else if (tab === 'risk') {
    const riskColor = { High:'var(--coral)', Medium:'var(--amber)', Low:'var(--blue)' };
    canvas.innerHTML = `
      <div class="page-header">
        <div><div class="page-title">At <span>Risk</span></div>
        <div class="page-sub">Learners flagged for low progress or inactivity — intervention required</div></div>
      </div>
      <div class="summary-strip">
        <div><div class="summary-item-label">High Risk</div><div class="summary-item-val" style="color:var(--coral);">${COMP_DEMO.atRisk.filter(r=>r.risk==='High').length}</div></div>
        <div><div class="summary-item-label">Medium Risk</div><div class="summary-item-val" style="color:var(--amber);">${COMP_DEMO.atRisk.filter(r=>r.risk==='Medium').length}</div></div>
        <div><div class="summary-item-label">Low Risk</div><div class="summary-item-val" style="color:var(--blue);">${COMP_DEMO.atRisk.filter(r=>r.risk==='Low').length}</div></div>
        <div><div class="summary-item-label">Unassigned Mentors</div><div class="summary-item-val" style="color:var(--amber);">${COMP_DEMO.atRisk.filter(r=>r.mentor==='Assign').length}</div></div>
      </div>
      <div class="data-table-wrap">
        <div style="display:grid;grid-template-columns:160px 140px 100px 110px 80px 120px;padding:10px 14px;background:var(--ink3);border-bottom:1px solid var(--border);font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);">
          <span>Learner</span><span>Program</span><span>Progress</span><span>Last Active</span><span>Risk</span><span>Mentor</span>
        </div>
        ${COMP_DEMO.atRisk.map(r=>`
          <div style="display:grid;grid-template-columns:160px 140px 100px 110px 80px 120px;padding:11px 14px;border-bottom:1px solid var(--border);align-items:center;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
            <span style="font-weight:600;">${r.name}</span>
            <span style="color:var(--muted2);">${r.program}</span>
            <span>
              <div style="display:flex;align-items:center;gap:6px;">
                <div class="prog-bar-wrap" style="width:50px;"><div class="prog-bar" style="width:${r.progress};background:${riskColor[r.risk]};"></div></div>
                <span style="color:${riskColor[r.risk]};font-size:11px;">${r.progress}</span>
              </div>
            </span>
            <span style="color:var(--coral);font-size:11px;">${r.lastActive}</span>
            <span><span style="display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:${riskColor[r.risk]}22;color:${riskColor[r.risk]};">${r.risk}</span></span>
            <span>${r.mentor==='Assign'?'<button class="filter-btn accent" style="font-size:10px;padding:3px 9px;">+ Assign</button>':'<span style="color:var(--teal);">'+r.mentor+'</span>'}</span>
          </div>`).join('')}
      </div>`;
  }
}

init();
</script>
</body>
</html>
